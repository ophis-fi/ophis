# Keep the build context small. The mcp-server stdio image only needs the root
# workspace manifests, apps/mcp-server, and packages/sdk (do NOT exclude those).
.git
**/node_modules
# Never copy secrets into the build context / image layers (defense-in-depth;
# the Dockerfile copies only selected paths, but exclude env files globally).
**/.env
**/.env.*
apps/frontend
apps/backend
contracts
**/dist
**/.turbo
**/.wrangler
**/.next
*.log
