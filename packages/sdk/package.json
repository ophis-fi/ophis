{
  "name": "@ophis/sdk",
  "version": "0.3.0",
  "description": "Integration helpers for Ophis (a CoW Protocol fork): correct orderbook hosts, the CIP-75 partner-fee appData fragment, the per-chain EIP-712 signing domain, and order receiver-safety guards.",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ophis-fi/ophis.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://docs.ophis.fi/ai-agents",
  "bugs": "https://github.com/ophis-fi/ophis/issues",
  "keywords": [
    "ophis",
    "cow-protocol",
    "cowswap",
    "dex",
    "dex-aggregator",
    "defi",
    "swap",
    "intent",
    "intent-based",
    "mev-protection",
    "gasless",
    "eip-712",
    "agent",
    "ai-agent",
    "mcp",
    "web3",
    "ethereum",
    "optimism",
    "base",
    "arbitrum"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
