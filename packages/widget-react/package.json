{
  "name": "@ophis/widget-react",
  "version": "0.0.1",
  "description": "Embed the Ophis swap widget in a React app. A thin, Ophis-branded wrapper over @cowprotocol/widget-react that defaults the iframe host to swap.ophis.fi and injects the Ophis appCode + CIP-75 partner fee.",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ophis-fi/ophis.git",
    "directory": "packages/widget-react"
  },
  "homepage": "https://docs.ophis.fi/widget",
  "bugs": "https://github.com/ophis-fi/ophis/issues",
  "keywords": [
    "ophis",
    "cow-protocol",
    "cowswap",
    "widget",
    "swap-widget",
    "react",
    "dex",
    "defi"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@cowprotocol/widget-react": "^3.1.1",
    "@ophis/sdk": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.3",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "typescript": "^5.5.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
