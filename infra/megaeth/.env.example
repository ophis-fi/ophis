# infra/megaeth/.env — Greg Phase 3 MegaETH deploy environment
# Copy to infra/megaeth/.env and fill in. NEVER commit infra/megaeth/.env.
# ---------------------------------------------------------------

# --- Networks ---
MEGAETH_TESTNET_RPC=https://carrot.megaeth.com/rpc
# 6343 (0x18c7) is the live MegaETH testnet. The plan originally referenced
# 6342, which is the deprecated previous testnet. Verified against
# `cast chain-id --rpc-url https://carrot.megaeth.com/rpc` returning 6343.
MEGAETH_TESTNET_CHAIN_ID=6343
MEGAETH_TESTNET_EXPLORER=https://megaexplorer.xyz

# Mainnet RPC + explorer to be confirmed at Stage-2 start (megaeth.com / chainlist.org).
MEGAETH_MAINNET_RPC=
MEGAETH_MAINNET_CHAIN_ID=4326
MEGAETH_MAINNET_EXPLORER=

# --- Deployer EOA (Greg) ---
# Private key in macOS Keychain entry `ophis-megaeth-deployer`.
OPHIS_MEGAETH_DEPLOYER_ADDRESS=0xb398C789F8690357e2b3D2ef6d1CDe62B1e4D020

# --- Driver submitter (reuse Phase 1) ---
# Private key in macOS Keychain entry `<keychain-service>`.
OPHIS_DRIVER_SUBMITTER_ADDRESS=0x92B9bE5e96795E8630fDC61efb0e705E75b1A1B1

# --- Greg-deployed contract addresses (filled after Tasks 4-5) ---
OPHIS_AUTH_TESTNET=
OPHIS_SETTLEMENT_TESTNET=
OPHIS_VAULT_RELAYER_TESTNET=
OPHIS_AUTH_MAINNET=
OPHIS_SETTLEMENT_MAINNET=
OPHIS_VAULT_RELAYER_MAINNET=

# --- Partner-fee recipient (unchanged from Phase 2.5) ---
# Gnosis Safe; CREATE2-deterministic; same address on MegaETH after lazy proxy deploy.
OPHIS_PARTNER_FEE_RECIPIENT=0x858f0F5eE954846D47155F5203c04aF1819eCeF8

# Ophis protocol Safe — owns AllowListAuthentication on MegaETH mainnet post-deploy
# (Spec 5 mandate). 2-of-2 with HW wallet + independent EOA.
OPHIS_PROTOCOL_SAFE_MEGAETH_MAINNET=0xe049a64546fb8564CC4c7D64A0A1BAe00Aa801cF
