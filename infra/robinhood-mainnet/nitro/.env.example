# infra/robinhood-mainnet/nitro/.env.example
# COPY to .env, fill in, chmod 600, NEVER COMMIT. (.env is gitignored.)
#
# The Nitro node validates Robinhood Chain (chainId 4663) by reading its batches
# and EIP-4844 blob DA from Ethereum L1. Both endpoints below are REQUIRED.

# ── L1 execution RPC (Ethereum mainnet JSON-RPC) ──────────────────────────────
# Nitro reads the Robinhood SequencerInbox batches from here. Prefer your own
# Ethereum node. Free fallback (rate-limited): https://ethereum-rpc.publicnode.com
L1_EXECUTION_RPC=

# ── L1 beacon (consensus) endpoint ────────────────────────────────────────────
# Robinhood posts DA as EIP-4844 blobs, which live on the beacon chain (not the
# execution layer).
#
# BLOB RETENTION IS THE BLOCKING CONSTRAINT - see README "From-genesis sync is
# not possible". Measured 2026-07-21 against ethereum-beacon-api.publicnode.com:
# blobs are served back ~45-50 days, then drop to nothing. The rollup deployed
# 2026-04-30 (82 days back), so the first ~32-37 days of this chain's DA is NOT
# retrievable from that endpoint. A from-genesis sync will stall there.
#
# You therefore need EITHER an archive beacon provider whose retention reaches
# back past 2026-04-30, OR a database snapshot (see README). Verify any candidate
# endpoint BEFORE committing to a multi-day sync:
#   curl -s "$L1_BEACON_URL/eth/v1/beacon/blobs/14229224" | head -c 120
#   # slot 14229224 ~= the rollup deploy. '"data":[]' => too shallow, will fail.
L1_BEACON_URL=

# ── Optional: fallback beacon ─────────────────────────────────────────────────
# Nitro supports ONE fallback via --parent-chain.blob-client.secondary-beacon-url.
# (There is NO --parent-chain.blob-client.blob-storage-service-urls flag - an
# earlier revision of this runbook invented it; verified absent from the Nitro
# source 2026-07-21. Passing it makes the node fail to start.)
L1_BEACON_URL_FALLBACK=
