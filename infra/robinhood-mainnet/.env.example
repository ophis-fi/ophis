# infra/robinhood-mainnet/.env.example - Ophis Robinhood Chain mainnet (chain 4663) secrets.
# COPY to .env, fill in, chmod 600, NEVER COMMIT. (.gitignore excludes .env.)
#
# The driver-submitter PK lives at /Users/ophis-driver/.config/submitter.key
# (Tier 1 PK isolation - same as OP/Unichain). Do NOT put it in this file.

# ── Database ──────────────────────────────────────────────────────────────
# Use a DIFFERENT DB password from the other stacks - separate Postgres instance.
POSTGRES_USER=ophis
POSTGRES_PASSWORD=
POSTGRES_DB=ophis
DB_WRITE_URL=postgresql://ophis:${POSTGRES_PASSWORD}@db:5432/ophis
DB_READ_URL=postgresql://ophis:${POSTGRES_PASSWORD}@db:5432/ophis

# ── Chain RPC ─────────────────────────────────────────────────────────────
# ROBINHOOD_MAINNET_RPC: direct RPC URL substituted into the lifi solver TOML
# template. The eRPC proxy uses its own 3 hardcoded upstreams and ignores this.
ROBINHOOD_MAINNET_RPC=https://rpc.mainnet.chain.robinhood.com

# ROBINHOOD_RPC_INTERNAL: optional bypass of the eRPC 2-of-3 consensus proxy.
# When set, ALL chain-reading services point at this single URL instead of
# http://rpc-proxy:4000/main/evm/4663. LEAVE EMPTY in normal operation.
# render-configs.sh + compose-up.sh REFUSE unless ALLOW_RPC_BYPASS=1 is also set.
ROBINHOOD_RPC_INTERNAL=

# ── Alchemy (3rd eRPC read leg) ───────────────────────────────────────────
# Free-tier Alchemy key for the robinhood-alchemy eRPC upstream. Alchemy is
# Robinhood's recommended provider. Get a free key at alchemy.com. See the RPC
# independence GATE in configs/erpc.yaml.tmpl (this may share a failure domain
# with the public RPC). Substituted into rendered/erpc.yaml.
ALCHEMY_API_KEY=

# ── Driver-submitter private key ──────────────────────────────────────────
# Tier 1 PK isolation: PK lives at /Users/ophis-driver/.config/submitter.key.
# render-configs.sh reads it via sudo. LEAVE EMPTY here.
OPHIS_DRIVER_SUBMITTER_KEY=

# ── Distributed tracing ───────────────────────────────────────────────────
# Set to http://jaeger:4317 to enable OTLP/gRPC tracing. Leave empty to disable.
TRACING_COLLECTOR_ENDPOINT=

# ── Observability (Prometheus + Alertmanager → Telegram) ─────────────────
# PREFERRED source: macOS Keychain (service=ophis-telegram-bot). Leave EMPTY here
# if using Keychain - render-configs.sh checks Keychain first.
TELEGRAM_BOT_TOKEN=

# ── CoinGecko (native-price oracle) ───────────────────────────────────────
# Required at startup. Free Demo key at coingecko.com/en/api/pricing. See the
# native-pricing GATE in configs/orderbook.toml.tmpl: CoinGecko may NOT list
# Robinhood Chain (4663) yet.
COINGECKO_API_KEY=

# ── Inter-service auth ────────────────────────────────────────────────────
# Shared Bearer token between autopilot <-> driver.
# Source from Keychain: security find-generic-password -s ophis-inter-service-auth-token -w
OPHIS_INTER_SERVICE_AUTH_TOKEN=

# ══ DEPLOY / LEDGER CEREMONY ONLY (not read by the stack) ══
# The 2-of-3 Ophis protocol Safe deployed ON ROBINHOOD (4663). Takes ownership +
# manager of AllowListAuthentication at the end of the ceremony. Safe 1.3.0/1.4.1
# factories are present on 4663 (verified), so protocol-kit can deploy it even if
# the hosted Safe UI does not index the chain.
OPHIS_PROTOCOL_SAFE_ROBINHOOD_MAINNET=
# Its 3 owner addresses (comma/space-separated). If set, the ceremony HARD-asserts
# every one is present (rejects a wrong-but-valid 2-of-3 Safe). Strongly recommended.
OPHIS_SAFE_EXPECTED_OWNERS=
