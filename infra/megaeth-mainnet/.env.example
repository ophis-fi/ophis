# infra/megaeth-mainnet/.env — Ophis MegaETH mainnet secrets.
# COPY this file to .env, fill in the secrets, NEVER COMMIT the populated form.
# .gitignore already excludes infra/megaeth-mainnet/.env.
#
# After copying, chmod 600 .env — render-configs.sh enforces this on every
# deploy but the initial copy is on the operator. This keeps the
# driver-submitter PK + OKX credentials owner-only at the filesystem layer.
# The Keychain entries listed below are the authoritative source; this
# .env is a deploy-time mirror.

# ── Database ──────────────────────────────────────────────────────────────
# Pick a strong random password (32+ chars). Different from testnet (which
# uses '123' for convenience). Generate via:
#   openssl rand -base64 32
POSTGRES_USER=ophis
POSTGRES_PASSWORD=
POSTGRES_DB=ophis
DB_WRITE_URL=postgresql://ophis:${POSTGRES_PASSWORD}@db:5432/ophis
DB_READ_URL=postgresql://ophis:${POSTGRES_PASSWORD}@db:5432/ophis

# ── Chain RPC ─────────────────────────────────────────────────────────────
# publicnode.com (free, no API key, eth_createAccessList works). Fallback to
# https://op-pokt.nodies.app by editing this if publicnode degrades.
MEGAETH_MAINNET_RPC=https://mainnet.megaeth.com/rpc

# ── Driver-submitter private key ──────────────────────────────────────────
# Corresponds to on-chain address 0x00f98b5776eb0f6a8c0c925ddF51f9Ade8a1502F,
# which was allowlisted in deploy-mainnet-all.sh Step 3 (addSolver). This EOA
# signs every settlement transaction. Treat like a hot-wallet key — keep
# balance bounded (~0.02 OP ETH, top up as needed) to cap blast radius.
#
# 32-byte hex, 0x-prefixed. Retrieve from macOS Keychain via:
#   security find-generic-password -s ophis-driver-submitter-op-mainnet -w
OPHIS_DRIVER_SUBMITTER_KEY=

