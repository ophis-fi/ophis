#!/usr/bin/env bash
# Weekly Safe-owners + AllowList drift detector.
#
# Snapshots on-chain ownership of the protocol Safe + AllowList manager
# on every active chain. Compares to expected, sends Telegram on drift.
#
# **Render with `render-safe-drift-check.sh`** to inject the Telegram
# bot token without committing it.
#
# Run cadence: weekly, via launchd plist `ai.ophis.safe-drift-check`.

set -euo pipefail
umask 077

# ----------------------------------------------------------------------
# Per-chain configuration. Add a stanza to enable a chain.
# Each chain expects: $name $chain_id $rpc $protocol_safe $partner_safe $allowlist_proxy $expected_submitter
# ----------------------------------------------------------------------
declare -a CHAINS=(
  # name|chain_id|rpc_url|protocol_safe|partner_safe|allowlist_proxy|expected_submitter|expected_manager|expected_proxy_owner
  # allowlist_proxy = Settlement.authenticator() (the real GPv2AllowListAuthentication).
  # expected_manager = AllowListGuardian; expected_proxy_owner = TimelockController
  # (both from the #442 migration; pre-migration both were the protocol Safe). When
  # expected_proxy_owner != protocol_safe the check ALSO verifies the Timelock's
  # getMinDelay() >= 24h + Safe proposer/executor roles. NOTE: the prior
  # allowlist_proxy 0x9eFDcC2770… had NO CODE on-chain.
  "optimism|10|https://mainnet.optimism.io|0xe049a64546fb8564CC4c7D64A0A1BAe00Aa801cF|0x858f0F5eE954846D47155F5203c04aF1819eCeF8|0xAAA13bC6C1A505ccE6B4BF262fdDf4c703B9BD70|0x92B9bE5e96795E8630fDC61efb0e705E75b1A1B1|0x327F8894caEd538525c3956Fcd694b374B26B6fC|0x8fEe42897a0113BbeC86e4caCCaC5787D7AEC373"
)

# Expected protocol Safe owners (lowercase 40-hex, space-separated).
# Updated when signers rotate via Safe vote — edit this script,
# git commit, push.
#
# Pre-flight guard below asserts every entry is a valid 40-hex address
# at startup. Placeholder strings (`0x...ledger2`) cause an immediate
# exit-1 — by design, so a half-configured script can't silently fire
# drift alerts on every check.
EXPECTED_PROTOCOL_OWNERS_SORTED='0x0494f503912c101bfd76b88e4f5d8a33de284d1a 0x746ad9c63cca6d3a8588731d60fb87deab4da46a 0xbec5b03ffdcac50071693e87bfdb88baa6710199'
EXPECTED_PROTOCOL_THRESHOLD=2

# Partner-fee Safe unified to 2-of-3 across all chains (2026-06-05), same owner
# set as the protocol Safe (was 2-of-2 / single-owner on Gnosis+Ethereum before).
EXPECTED_PARTNER_OWNERS_SORTED='0x0494f503912c101bfd76b88e4f5d8a33de284d1a 0x746ad9c63cca6d3a8588731d60fb87deab4da46a 0xbec5b03ffdcac50071693e87bfdb88baa6710199'
EXPECTED_PARTNER_THRESHOLD=2

# Pre-flight: refuse to run with placeholder OR malformed addresses.
# Also validates the CHAINS array — each pipe-separated address field
# must be a canonical 40-hex string (catches off-by-one typos in
# allowlist_proxy / safe addresses that would otherwise produce silent
# `cast call` failures and weekly alert noise).
for chain_row in "${CHAINS[@]}"; do
  IFS='|' read -r _ _ _ proto_safe partner_safe allowlist_proxy submitter expected_manager expected_proxy_owner <<< "$chain_row"
  for addr in "$proto_safe" "$partner_safe" "$allowlist_proxy" "$submitter" "$expected_manager" "$expected_proxy_owner"; do
    if [[ ! "$addr" =~ ^0x[0-9a-fA-F]{40}$ ]]; then
      echo "ERROR: CHAINS row has invalid address: '$addr' (must be 0x + 40 hex)" >&2
      echo "  Row: $chain_row" >&2
      exit 1
    fi
  done
done

for expected_var in EXPECTED_PROTOCOL_OWNERS_SORTED EXPECTED_PARTNER_OWNERS_SORTED; do
  for addr in ${!expected_var}; do
    if [[ ! "$addr" =~ ^0x[0-9a-fA-F]{40}$ ]]; then
      echo "ERROR: ${expected_var} contains non-address token: '$addr'" >&2
      echo "  Edit safe-drift-check.sh.tmpl and replace placeholders" >&2
      echo "  (e.g. '0x...ledger2') with real 40-hex addresses." >&2
      exit 1
    fi
  done
done

# Default to the OP token file — OP is the only live monitored chain (CHAINS
# above is optimism-only) and the sibling settlement-anomaly-watch.sh uses the
# same path. The old hyperevm default pointed at a torn-down chain's token, so
# under set -euo pipefail alert() would abort on the missing file. (#211)
TELEGRAM_BOT_TOKEN_FILE="${TELEGRAM_BOT_TOKEN_FILE:-/Users/scep/greg/infra/optimism-mainnet/observability-rendered/telegram-token}"
TELEGRAM_CHAT_ID="${TELEGRAM_CHAT_ID:-735726338}"
LOGFILE="${LOGFILE:-${HOME}/Library/Logs/ophis-safe-drift-check.log}"

# ----------------------------------------------------------------------

log() {
  printf '[%s] %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" >> "$LOGFILE"
}

alert() {
  local msg="$1"
  log "ALERT: $msg"
  local token
  token="$(< "$TELEGRAM_BOT_TOKEN_FILE")"
  curl -sm 10 -X POST \
    "https://api.telegram.org/bot${token}/sendMessage" \
    -d "chat_id=${TELEGRAM_CHAT_ID}" \
    -d "parse_mode=HTML" \
    --data-urlencode "text=<b>🚨 Ophis Safe drift</b>%0A${msg}" \
    >/dev/null 2>&1 || log "WARN: telegram send failed"
}

# Assert an OZ AccessControl role on $tl has EXACTLY one member == $want.
# Catches a missing expected holder AND any extra/rogue holder (granted
# deployer/EOA/admin) that a plain hasRole($want) check would miss.
check_sole_role_member() {
  local rpc="$1" tl="$2" role_name="$3" want="$4" cname="$5" label="$6" blk="$7"
  local role count_raw count member_raw member
  role="$(cast keccak "$role_name")"
  # Both reads pinned to the same block ($blk) and failure-guarded: an RPC flake
  # or revert must alert + return, not exit the cron under set -euo pipefail
  # (the `| head | awk` pipeline still propagates cast's non-zero via pipefail).
  count_raw="$(cast call --block "$blk" --rpc-url "$rpc" "$tl" 'getRoleMemberCount(bytes32)(uint256)' "$role" 2>&1)" || {
    alert "Timelock ${label} getRoleMemberCount call failed on $cname: $count_raw"
    return
  }
  count="$(echo "$count_raw" | head -1 | awk '{print $1}')"
  if [[ ! "$count" =~ ^[0-9]+$ ]]; then
    alert "Timelock ${label} getRoleMemberCount non-numeric on $cname: $count_raw"
    return
  fi
  if [[ "$count" != "1" ]]; then
    alert "Timelock ${label} role has ${count} holders on <b>$cname</b> (expected exactly 1 = <code>${want}</code>) — enumerate getRoleMember to find extras"
    return
  fi
  member_raw="$(cast call --block "$blk" --rpc-url "$rpc" "$tl" 'getRoleMember(bytes32,uint256)(address)' "$role" 0 2>&1)" || {
    alert "Timelock ${label} getRoleMember call failed on $cname: $member_raw"
    return
  }
  member="$(echo "$member_raw" | head -1 | awk '{print $1}' | tr '[:upper:]' '[:lower:]')"
  if [[ "$member" != "$want" ]]; then
    alert "Timelock ${label} sole holder drift on <b>$cname</b>%0Aexpected: <code>${want}</code>%0Aactual:   <code>${member}</code>"
  fi
}

normalize_addresses() {
  # Convert `cast call ... 'getOwners()(address[])'` output to
  # space-separated lowercase addresses, sorted.
  #
  # Codex MED (PR #117): the prior implementation matched ANY
  # `0x[a-fA-F0-9]{40}` token in the input — including ones that
  # appear in error messages. If `cast` ever printed
  # "Error: revert at 0xdeadbeef..." (40+ hex chars), the addresses
  # would be silently included in the comparison set, producing
  # misleading drift.
  #
  # Fix: require the input to start with `[` (cast's array format).
  # Anything else fails the regex check at caller's site.
  local input="$1"
  if [[ "$input" != "["* ]]; then
    echo ""  # caller's regex/length check will trip
    return
  fi
  echo "$input" \
    | grep -oE '0x[0-9a-fA-F]{40}' \
    | tr '[:upper:]' '[:lower:]' \
    | sort -u \
    | tr '\n' ' ' \
    | sed 's/ *$//'
}

check_chain() {
  local stanza="$1"
  IFS='|' read -r name chain_id rpc protocol_safe partner_safe allowlist_proxy expected_submitter expected_manager expected_proxy_owner <<< "$stanza"

  log "checking chain=$name (chain_id=$chain_id)"

  # --- Protocol Safe owners ---
  local proto_owners
  proto_owners="$(cast call --rpc-url "$rpc" "$protocol_safe" 'getOwners()(address[])' 2>&1)" || {
    alert "Protocol Safe getOwners() failed on $name: $proto_owners"
    return
  }
  local proto_owners_norm
  proto_owners_norm="$(normalize_addresses "$proto_owners")"
  if [[ -z "$proto_owners_norm" ]]; then
    alert "Protocol Safe getOwners() on $name returned unparseable output (expected ABI array): $proto_owners"
    return
  fi
  local expected_proto_norm
  expected_proto_norm="$(echo "$EXPECTED_PROTOCOL_OWNERS_SORTED" | tr '[:upper:]' '[:lower:]' | tr ' ' '\n' | sort -u | tr '\n' ' ' | sed 's/ *$//')"
  if [[ "$proto_owners_norm" != "$expected_proto_norm" ]]; then
    alert "Protocol Safe owners drift on <b>$name</b>%0Aexpected: <code>${expected_proto_norm}</code>%0Aactual:   <code>${proto_owners_norm}</code>"
  fi

  # --- Protocol Safe threshold ---
  # All cast calls below use the same try-or-alert pattern getOwners
  # uses above. Pre-PR, threshold/manager/isSolver lacked the explicit
  # error-handling guard — under `set -euo pipefail` a failing cast
  # could abort the whole run, or worse, error output could parse as
  # a plausible-but-wrong value (Codex MED, PR #117 review).
  local proto_thr_raw
  proto_thr_raw="$(cast call --rpc-url "$rpc" "$protocol_safe" 'getThreshold()(uint256)' 2>&1)" || {
    alert "Protocol Safe getThreshold() failed on $name: $proto_thr_raw"
    return
  }
  local proto_thr
  proto_thr="$(echo "$proto_thr_raw" | head -1 | awk '{print $1}')"
  # Strict numeric check — guards against MED-2 (40-hex contamination
  # of error output that would otherwise parse as a number).
  if [[ ! "$proto_thr" =~ ^[0-9]+$ ]]; then
    alert "Protocol Safe getThreshold() on $name returned non-numeric: $proto_thr_raw"
    return
  fi
  if [[ "$proto_thr" != "$EXPECTED_PROTOCOL_THRESHOLD" ]]; then
    alert "Protocol Safe threshold drift on <b>$name</b>%0Aexpected ${EXPECTED_PROTOCOL_THRESHOLD}, actual ${proto_thr}"
  fi

  # --- Partner-fee Safe owners ---
  local partner_owners
  partner_owners="$(cast call --rpc-url "$rpc" "$partner_safe" 'getOwners()(address[])' 2>&1)" || {
    log "WARN: partner Safe not deployed yet on $name (CREATE2 lazy) — skipping"
    return
  }
  local partner_owners_norm
  partner_owners_norm="$(normalize_addresses "$partner_owners")"
  if [[ -z "$partner_owners_norm" ]]; then
    alert "Partner-fee Safe getOwners() on $name returned unparseable output: $partner_owners"
    return
  fi
  local expected_partner_norm
  expected_partner_norm="$(echo "$EXPECTED_PARTNER_OWNERS_SORTED" | tr '[:upper:]' '[:lower:]' | tr ' ' '\n' | sort -u | tr '\n' ' ' | sed 's/ *$//')"
  if [[ "$partner_owners_norm" != "$expected_partner_norm" ]]; then
    alert "Partner-fee Safe owners drift on <b>$name</b>%0Aexpected: <code>${expected_partner_norm}</code>%0Aactual:   <code>${partner_owners_norm}</code>"
  fi
  local partner_thr_raw partner_thr
  partner_thr_raw="$(cast call --rpc-url "$rpc" "$partner_safe" 'getThreshold()(uint256)' 2>&1)" || {
    alert "Partner-fee Safe getThreshold() call failed on $name: $partner_thr_raw"
    return
  }
  partner_thr="$(echo "$partner_thr_raw" | head -1 | awk '{print $1}')"
  if [[ "$partner_thr" != "$EXPECTED_PARTNER_THRESHOLD" ]]; then
    alert "Partner-fee Safe threshold drift on <b>$name</b>%0Aexpected ${EXPECTED_PARTNER_THRESHOLD}, actual ${partner_thr}"
  fi

  # --- AllowList manager points at the expected manager (AllowListGuardian post-#442) ---
  local manager_raw
  manager_raw="$(cast call --rpc-url "$rpc" "$allowlist_proxy" 'manager()(address)' 2>&1)" || {
    alert "AllowList manager() call failed on $name: $manager_raw"
    return
  }
  local manager
  manager="$(echo "$manager_raw" | head -1 | awk '{print $1}' | tr '[:upper:]' '[:lower:]')"
  if [[ ! "$manager" =~ ^0x[0-9a-f]{40}$ ]]; then
    alert "AllowList manager() on $name returned non-address: $manager_raw"
    return
  fi
  local expected_manager_lower
  expected_manager_lower="$(echo "$expected_manager" | tr '[:upper:]' '[:lower:]')"
  if [[ "$manager" != "$expected_manager_lower" ]]; then
    alert "AllowList manager drift on <b>$name</b>%0Aexpected: <code>${expected_manager_lower}</code>%0Aactual:   <code>${manager}</code>"
  fi

  # --- AllowList proxy owner() == expected proxy owner (Timelock post-#442) ---
  # The 24h UPGRADE delay depends on owner()==Timelock; a transfer back to a
  # Safe/EOA would un-delay upgradeTo even while manager() stays the Guardian.
  local owner_raw owner_addr expected_owner_lower proto_lower auth_lower
  owner_raw="$(cast call --rpc-url "$rpc" "$allowlist_proxy" 'owner()(address)' 2>&1)" || {
    alert "AllowList owner() call failed on $name: $owner_raw"
    return
  }
  owner_addr="$(echo "$owner_raw" | head -1 | awk '{print $1}' | tr '[:upper:]' '[:lower:]')"
  expected_owner_lower="$(echo "$expected_proxy_owner" | tr '[:upper:]' '[:lower:]')"
  proto_lower="$(echo "$protocol_safe" | tr '[:upper:]' '[:lower:]')"
  auth_lower="$(echo "$allowlist_proxy" | tr '[:upper:]' '[:lower:]')"
  if [[ "$owner_addr" != "$expected_owner_lower" ]]; then
    alert "AllowList proxy owner drift on <b>$name</b>%0Aexpected: <code>${expected_owner_lower}</code>%0Aactual:   <code>${owner_addr}</code>"
  fi

  # --- AllowListGuardian internal wiring (only when a Guardian is the manager) ---
  # guardian() (fast removeSolver authority) must be the Safe; immutable
  # timelock()/authenticator() must match — else the configured manager is a
  # wrong/rogue Guardian and the instant-eviction path isn't Safe-controlled.
  if [[ "$expected_manager_lower" != "$proto_lower" ]]; then
    local g_guardian g_timelock g_auth
    g_guardian="$(cast call --rpc-url "$rpc" "$expected_manager" 'guardian()(address)' 2>&1)" || {
      alert "Guardian guardian() call failed on $name: $g_guardian"; return
    }
    g_guardian="$(echo "$g_guardian" | head -1 | awk '{print $1}' | tr '[:upper:]' '[:lower:]')"
    [[ "$g_guardian" != "$proto_lower" ]] && alert "Guardian fast-path guardian() drift on <b>$name</b>%0Aexpected Safe <code>${proto_lower}</code>, actual <code>${g_guardian}</code>"
    g_timelock="$(cast call --rpc-url "$rpc" "$expected_manager" 'timelock()(address)' 2>&1)" || {
      alert "Guardian timelock() call failed on $name: $g_timelock"; return
    }
    g_timelock="$(echo "$g_timelock" | head -1 | awk '{print $1}' | tr '[:upper:]' '[:lower:]')"
    [[ "$g_timelock" != "$expected_owner_lower" ]] && alert "Guardian timelock() drift on <b>$name</b>%0Aexpected <code>${expected_owner_lower}</code>, actual <code>${g_timelock}</code>"
    g_auth="$(cast call --rpc-url "$rpc" "$expected_manager" 'authenticator()(address)' 2>&1)" || {
      alert "Guardian authenticator() call failed on $name: $g_auth"; return
    }
    g_auth="$(echo "$g_auth" | head -1 | awk '{print $1}' | tr '[:upper:]' '[:lower:]')"
    [[ "$g_auth" != "$auth_lower" ]] && alert "Guardian authenticator() drift on <b>$name</b>%0Aexpected <code>${auth_lower}</code>, actual <code>${g_auth}</code>"
  fi

  # --- Timelock health (only when a Timelock governs upgrades: owner != Safe) ---
  # getMinDelay >= 24h AND each role held by EXACTLY the expected sole member
  # (enumerated, so an extra/rogue proposer/executor/admin is caught too).
  if [[ "$expected_owner_lower" != "$proto_lower" ]]; then
    # Pin every Timelock read to ONE block so getMinDelay + the per-role
    # count/member enumeration form a coherent snapshot. OZ warns enumeration
    # must be same-block: a grant/revoke mined between getRoleMemberCount and
    # getRoleMember could otherwise certify a role while a rogue holder slips in
    # at a higher index (count==1 at block N, extra added at N+1, index 0 still
    # the Safe -> the check would pass and miss the extra holder).
    local tl_blk min_delay_raw min_delay
    tl_blk="$(cast block-number --rpc-url "$rpc" 2>&1)" || {
      alert "block-number for Timelock checks failed on $name: $tl_blk"; return
    }
    min_delay_raw="$(cast call --block "$tl_blk" --rpc-url "$rpc" "$expected_proxy_owner" 'getMinDelay()(uint256)' 2>&1)" || {
      alert "Timelock getMinDelay() call failed on $name: $min_delay_raw"; return
    }
    min_delay="$(echo "$min_delay_raw" | head -1 | awk '{print $1}')"
    if [[ ! "$min_delay" =~ ^[0-9]+$ ]] || (( min_delay < 86400 )); then
      alert "Timelock getMinDelay drift on <b>$name</b>%0Aexpected >= 86400 (24h), actual: <code>${min_delay}</code>"
    fi
    check_sole_role_member "$rpc" "$expected_proxy_owner" "PROPOSER_ROLE" "$proto_lower" "$name" "proposer" "$tl_blk"
    check_sole_role_member "$rpc" "$expected_proxy_owner" "EXECUTOR_ROLE" "$proto_lower" "$name" "executor" "$tl_blk"
    check_sole_role_member "$rpc" "$expected_proxy_owner" "TIMELOCK_ADMIN_ROLE" "$expected_owner_lower" "$name" "admin (self)" "$tl_blk"
  fi

  # --- Expected submitter is allowlisted ---
  local is_allowed_raw
  is_allowed_raw="$(cast call --rpc-url "$rpc" "$allowlist_proxy" 'isSolver(address)(bool)' "$expected_submitter" 2>&1)" || {
    alert "isSolver() call failed on $name: $is_allowed_raw"
    return
  }
  local is_allowed
  is_allowed="$(echo "$is_allowed_raw" | head -1)"
  if [[ "$is_allowed" != "true" ]] && [[ "$is_allowed" != "false" ]]; then
    alert "isSolver() on $name returned non-bool: $is_allowed_raw"
    return
  fi
  if [[ "$is_allowed" != "true" ]]; then
    alert "Submitter EOA <code>${expected_submitter}</code> NOT allowlisted on <b>$name</b> (isSolver returned: ${is_allowed})"
  fi

  log "chain=$name passed all checks"
}

mkdir -p "$(dirname "$LOGFILE")"
log "=== Safe drift check starting ==="

for stanza in "${CHAINS[@]}"; do
  check_chain "$stanza"
done

log "=== Safe drift check complete ==="
