# Ophis — Optimism mainnet (chain 10) OKX aggregator solver config.
#
# TEMPLATE FILE. Render with envsubst at deploy time:
#   ./render-configs.sh
#
# The CoW solver TOML parser does NOT interpolate $VARS at parse time, so we
# pre-render this template into rendered/okx.toml (gitignored) before
# mounting it into the okx-solver container.

node-url = "${OP_MAINNET_RPC}"

# Ophis-fork settlement contract on Optimism. Without this override the
# solver framework falls back to GPv2Settlement::deployment_address(),
# which is the canonical CoW address 0x9008d19f…ab41. The OKX call
# would then bake that wrong `swapReceiverAddress` into its swap
# calldata: settle() pulls WETH from OUR settlement, OKX deposits USDC
# into the CoW canonical (empty) address, and the final user-payout
# transfer reverts with "ERC20: transfer amount exceeds balance".
settlement = "0x310784c7FCE12d578dA6f53460777bAc9718B859"

[dex]
# Chain ID 10 = Optimism mainnet.
chain-id = "10"

# OKX V6 DEX Aggregator API endpoint (sell orders / exactIn).
sell-orders-endpoint = "https://web3.okx.com/api/v6/dex/aggregator/"

# OKX V5 API is DEPRECATED (code 50050 "Please upgrade to V6"). V6 is
# sell-only. We accept that OKX can't quote the buy-direction probe
# anymore; orderbook quoting must work without it. Leaving disabled.
# buy-orders-endpoint = "https://www.okx.com/api/v5/dex/aggregator/"

# OKX OnchainOS credentials. Rendered from .env at deploy time.
api-project-id = "${OKX_PROJECT_ID}"
api-key = "${OKX_API_KEY}"
api-secret-key = "${OKX_SECRET_KEY}"
api-passphrase = "${OKX_PASSPHRASE}"

# Price-impact protection. 1.0 = disabled (we let CoW's solver-side
# slippage handle this). OKX's default is 0.9 (90%); explicit 1.0 avoids
# their server-side rejection at higher impact, since CoW does its own check.
price-impact-protection-percent = 1.0
