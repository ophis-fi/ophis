# Ophis — Optimism mainnet (chain 10) driver config.
#
# Liquidity sources are UniV2-shaped AMMs only. The CoW driver schema we ship
# doesn't speak Uniswap V3 / Velodrome V2's Solidly invariant yet. Quotes that
# need V3-only pools will fail-no-quote, not fail-unsafe — orders just won't
# match through the baseline solver until a V3-aware solver joins.
app-data-fetching-enabled = true
orderbook-url = "http://orderbook"
tx-gas-limit = "30000000"

# Skip eth_createAccessList preflight before settlement simulation.
#
# Original (pre-eRPC) rationale: public OP RPCs (publicnode, ankr) return
# `"storageKeys": null` for empty entries on complex traces, which trips
# alloy's strict deserializer in the driver and surfaces as a confusing
# Simulation Revert error.
#
# Phase 4 audit M-4 (2026-05-19) — partial fix landed, full re-enable
# deferred:
#
# AL simulation is a defense-in-depth check (predicts on-chain settle()
# success more accurately than bare eth_call). Disabling it means we
# trust the bare-call simulation alone. Pre-eRPC this was a real risk:
# any single hostile upstream answering eth_call with a fake success
# could trick the driver into broadcasting a tx that reverts on real
# chain (cost: gas only, but a sustained attack costs the 0.02 ETH
# driver budget).
#
# Post-#130 (eRPC + 2-of-3 consensus on eth_call): the bare-call path
# IS now consensus-protected. The marginal value of AL preflight on top
# of consensus is much smaller — AL catches a narrow case where
# simulation passes but settle() fails due to mid-tx storage changes
# (rare on OP given 2s block times + our access-pattern).
#
# Net: keeping disable=true here is now LOW residual risk. Flipping to
# false requires either (a) an alloy version that tolerates null
# storageKeys, OR (b) eRPC response normalization mapping null → [].
# Tracked as a follow-up; not blocking on this PR.
disable-access-list-simulation = true

[contracts]
gp-v2-settlement = "0x310784c7FCE12d578dA6f53460777bAc9718B859"
weth = "0x4200000000000000000000000000000000000006"
balances = "0x78799f98276efba1edeed32eae03a3fd8cdfec3a"
signatures = "0x5f315a204e7971fc29a66fef3a5773f6b0202fac"

[[solver]]
name = "baseline"
endpoint = "http://baseline"
absolute-slippage = "40000000000000000"  # 0.04 ETH in wei
relative-slippage = "0.1"
# Driver-submitter EOA 0x00f98b5776eb0f6a8c0c925ddF51f9Ade8a1502F — its private
# key is injected from container env (set via .env in this directory). The CoW
# config crate substitutes %VAR_NAME at load time.
account = "${OPHIS_DRIVER_SUBMITTER_KEY}"

# OKX OnchainOS aggregator — covers UniV3 + Velodrome + Curve + Balancer + long
# tail. Same driver-submitter EOA signs settlement (the auction picks whichever
# solver returns the best quote per order). Quote requests cost OKX free-quota
# credits ($100 Basic + $50 Premium per month, permanent).
[[solver]]
name = "okx"
endpoint = "http://okx-solver"
absolute-slippage = "40000000000000000"  # 0.04 ETH in wei
relative-slippage = "0.1"
account = "${OPHIS_DRIVER_SUBMITTER_KEY}"

# KyberSwap aggregator — second competing solver. Covers the same UniV3 +
# Velodrome + Curve + Balancer surface as OKX. Free public API, no key
# required. Two competing aggregators give the per-batch auction real
# price competition; whichever returns the better quote wins each order.
[[solver]]
name = "kyberswap"
endpoint = "http://kyberswap-solver"
absolute-slippage = "40000000000000000"  # 0.04 ETH in wei
relative-slippage = "0.1"
account = "${OPHIS_DRIVER_SUBMITTER_KEY}"

# Velora (formerly ParaSwap) aggregator — third competing solver.
# Augustus V6.2 deployed deterministically on OP at
# 0x6a000f20005980200259b80c5102003040001068 (allowlisted in
# dex::velora::VELORA_ROUTER_ALLOWLIST). With 3 aggregators competing
# per batch we get real auction pressure on routing quality and
# resilience against any single API outage.
#
# Velora's DEX coverage on OP partially overlaps OKX/Kyber (UniV3,
# Velodrome, Curve, Balancer) plus a few private market makers. Where
# they overlap, different routing algorithms (Kyber MDP vs. Velora MPA)
# produce different splits — surplus tightens at the CIP-75 cut.
[[solver]]
name = "velora"
endpoint = "http://velora-solver"
absolute-slippage = "40000000000000000"  # 0.04 ETH in wei
relative-slippage = "0.1"
account = "${OPHIS_DRIVER_SUBMITTER_KEY}"

[submission]
# OP mainnet typical L2 gas price is 0.001-0.05 gwei (1 Mgwei = 10^15 wei
# domain, often ~10^-3 gwei). The prior cap of 1000 gwei (10^12 wei) was
# 4-5 orders of magnitude above any realistic spike — so wide it provided
# essentially no protection against a pathological RPC misreport that
# fakes a price spike (e.g. a hostile upstream returning eth_gasPrice =
# 999 gwei would still pass the cap, then drain the driver-submitter's
# 0.02 ETH ceiling on a single bad batch).
#
# Phase 4 audit M-3 (2026-05-19): tighten to 5 gwei. 5 gwei is still
# ~100× higher than realistic OP traffic and absorbs genuine L1
# base-fee + blob-gas surges; below this is impossible-to-fake territory.
# Empirically over the last 30d OP gasPrice never exceeded 1 gwei.
gas-price-cap = "5000000000"

# Submission mempools — RACED in parallel (Phase 1.4, 2026-05-20).
#
# On OP mainnet there is a single sequencer (Optimism Foundation),
# so "private mempool" in the L1 sense doesn't exist. The MEV residual
# is the brief signing→inclusion window where an attacker on the
# submission RPC could observe signed calldata and front-run by
# submitting their own tx via a different relay.
#
# Mitigation: submit through MULTIPLE independent relays. The driver
# races all entries; first to accept wins, others get dropped. A
# hostile single relay can no longer reliably front-run because the
# sequencer may see one of the other entries' submissions first.
#
# 3 independent relays:
#   1. publicnode (Allnodes; DNS: Cloudflare)
#   2. mainnet.optimism.io (Optimism Foundation; Conduit/CF-fronted —
#      same DNS provider as publicnode but DIFFERENT operator)
#   3. Tenderly public gateway (Tenderly; DNS: Google Cloud — distinct
#      DNS provider entirely)
#
# All three eventually deliver to the same sequencer. Trust model:
# at least one of the three must be honest for an attacker NOT to
# successfully front-run. With 3 independent operators across 2 DNS
# providers, single-operator + single-DNS-incident scenarios are
# defended against.
[[submission.mempool]]
url = "https://optimism-rpc.publicnode.com"

[[submission.mempool]]
url = "https://mainnet.optimism.io"

[[submission.mempool]]
url = "https://optimism.gateway.tenderly.co"

[liquidity]
base-tokens = [
  "0x4200000000000000000000000000000000000006",  # WETH (OP Stack predeploy)
  "0x0b2C639c533813f4Aa9D7837CAf62653d097Ff85",  # USDC (canonical)
]

# SushiSwap V2 on Optimism — only V2-shaped AMM on OP with non-trivial
# liquidity. Standard UniV2 fork, same init-code hash. Uniswap Labs never
# officially deployed V2 on OP; Velodrome V2 is a Solidly fork with a
# different invariant that this driver can't read.
#
# Real liquidity on OP lives in Uniswap V3 (0.05% WETH/USDC), Velodrome V3,
# and Beethoven balancer pools — none of which the current driver schema
# understands. Spec 8 (V3 solver integration) tracks the upgrade.
[[liquidity.uniswap-v2]]
router = "0x2ABf469074dc0b54d793850807E6eb5Faf2625b1"
pool-code = "0x96e8ac4277198ff8b6f785478aa9a39f403cb768dd02cbee326c3e7da348845f"
missing-pool-cache-time = "5m"
