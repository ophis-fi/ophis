# infra/optimism/node/.env.example
# Copy to .env and fill in. Never commit the real .env.
#
# ---------------------------------------------------------------------------
# OP_NODE_L1_ETH_RPC  (required)
# ---------------------------------------------------------------------------
# L1 Ethereum execution-layer JSON-RPC URL that op-node follows to derive the
# L2 chain. Must support standard eth_* methods and (ideally) eth_getProof.
# Snap-sync from genesis is NOT what this drives — op-node only needs L1 head
# + receipts for batch derivation, so a free public RPC is usually fine.
#
# Free public options (pick one, or front-load via a wrapper for redundancy):
#   https://eth.llamarpc.com
#   https://ethereum-rpc.publicnode.com
#   https://rpc.ankr.com/eth
#   https://eth.drpc.org
#
# Paid (recommended for stability): Alchemy, Infura, QuickNode, dRPC paid tier.
#
# NOTE 2026-05-12 — `eth.llamarpc.com` was blocked at the Cloudflare edge
# from our Aleph VM's egress IP, returning 503 for every request. Pick a
# different provider if you hit the same. `ethereum-rpc.publicnode.com`
# worked reliably in testing.
OP_NODE_L1_ETH_RPC=https://ethereum-rpc.publicnode.com

# ---------------------------------------------------------------------------
# OP_NODE_L1_BEACON  (required since Ecotone, hard-fail without it)
# ---------------------------------------------------------------------------
# L1 consensus-layer (beacon chain) REST API URL. op-node fetches blob-
# sidecars from here to derive post-Ecotone batches (EIP-4844 blobs replaced
# calldata for batch submission). Many tutorials omit this and the node
# silently stalls on the Ecotone activation block — DO NOT SKIP.
#
# Free public options:
#   https://www.lightclientdata.org
#   https://ethereum-beacon-api.publicnode.com
#   https://eth-beacon-chain.drpc.org/rest/
#
# Self-hosted is best if you already run a Lighthouse / Prysm / Teku node.
#
# NOTE 2026-05-12 — `www.lightclientdata.org` was returning 503s during
# initial setup; `ethereum-beacon-api.publicnode.com` worked reliably.
OP_NODE_L1_BEACON=https://ethereum-beacon-api.publicnode.com

# ---------------------------------------------------------------------------
# OP_NODE_L1_TRUST_RPC  (optional, default: true)
# ---------------------------------------------------------------------------
# When true, op-node trusts the L1 RPC's reported chain head without
# cross-verifying via eth_getProof. Required for most free public L1 RPCs
# which don't expose proof endpoints. Set to false ONLY if you front op-node
# with your own L1 execution client.
OP_NODE_L1_TRUST_RPC=true
