# Ophis — HyperEVM mainnet (chain 999) autopilot config.
node-url = "${HYPEREVM_RPC_INTERNAL}"
simulation-node-url = "${HYPEREVM_RPC_INTERNAL}"

# Per-order wait while the run loop fetches a missing native (ETH-
# denominated) token price. Defaults to 0ns, which makes the auction
# filter any order whose token prices aren't already cached. The
# CoinGecko simple/token_price endpoint typically answers in 200-500ms
# so 5s is generous and covers a cold cache after restart.
native-price-timeout = "5s"

# HyperEVM Alchemy + public RPCs both reject block 0 lookups (Alchemy:
# -32001 "Unable to complete request"; public: -32603 "invalid block height: 0").
# Without skip-event-sync, the autopilot tries to backfill Settlement +
# CoW AMM + EthFlow events from genesis every block, logs "failed to
# fetch block 0" each time, and never marks essential maintenance done.
# We have no historical events to backfill (Settlement deployed at block
# 35173733, no prior CoW activity on HL), so starting from "latest" is
# correct. autopilot::run.rs:391 routes `skip_event_sync_start` to all
# three event indexers.
[ethflow]
# EthFlow contract for native HYPE → ERC-20 swaps. Deployed 2026-05-17 from
# 0xb398C789…D020 (CREATE nonce 13). Constructor: (settlement, WHYPE).
# Verified on-chain: WHYPE→VaultRelayer allowance is MAX_UINT256.
contracts = ["0xd031Ce1C577caD1530BD8283CaA6a6a106A5b61B"]
# Block NUMBER (not timestamp, despite the upstream doc comment — see
# find_indexing_start_block in ethflow_events.rs:272-279 which passes this
# straight to BlockNumberOrTag::Number()). Deploy block was 35347278; we
# round down to 35347000 for safety.
indexing-start = 35347000
# Keep `skip-event-sync = true` for HL. The sharp-edges audit (2026-05-17)
# caught that `false` is a boot-time panic on fresh-DB restart: the
# upstream `GPv2Settlement::deployment_info(999)` codegen returns None
# for chain 999 (we deploy our own settlement at 0x0864…, not the
# canonical one), so the settlement indexer falls back to block 0 and
# HyperEVM RPC rejects eth_getBlockByNumber(0). Setting skip-event-sync
# = true uses BlockNumberOrTag::Latest as start, which avoids the rejection.
# The OnchainOrderParser will still index NEW CreatedOrder events emitted
# after autopilot start; we just don't backfill the (currently empty)
# pre-deploy history. Re-evaluate if/when we regenerate the contracts
# crate with chain 999 deployment info baked in.
skip-event-sync = true

[contracts]
settlement = "0x0864b65F1EFe752a699d119Ae0419E7331a8Bfce"
balances = "0x764fe4aa1ff493cf39931c7923c8ff5837596504"
signatures = "0xe4137bd2ecfdfb96d80629ec254dadec71bc498c"
native-token = "0x5555555555555555555555555555555555555555"
hooks = "0x29fcdbbdffd12fa7724b863991355b82ba8380e2"
balancer-v2-vault = "0xBA12222222228d8Ba445958a75a0704d566BF2C8"

[logging]
filter = "warn,autopilot=debug,shared=info,price_estimation=info"

[current-block]
poll-interval = "2s"  # OP block time

[run-loop]
solve-deadline = "20s"
# 2026-05-17: bump submission-deadline from upstream default 5 blocks → 60.
# Default was tuned for mainnet (12s blocks, 5 = 60s window). HL has ~1s
# blocks, so 5 = 5s — way too tight. Every settle tx expired before
# inclusion, triggering a cancel-and-replace cycle that consumed ~30s per
# auction. A 5-min user delay (autopilot logs from 16:59:21–17:04:01)
# was traced to ~10 such retries before one finally landed.
#
# 60 blocks ≈ 60s on HL = matches mainnet effective behaviour. Safe upper
# bound: well under the autopilot solve cadence so the auction queue
# doesn't stall waiting for a single stuck settle.
submission-deadline = 60

# Audit HIGH-4 (2026-05-17): max-settlement-transaction-wait MUST strictly
# exceed submission-deadline × block-time, otherwise the autopilot stops
# watching for a tx (at wait expiry) while the deadline still permits it
# to land. Default is 1 min; with submission-deadline=60 at HL ~1s blocks
# = 60s, that's a 0-margin race. Bumped to 120s to absorb big-block jitter
# (HL's 60s big-block frame can push complex settles 30-60s late) and a
# multi-block reorg cushion.
max-settlement-transaction-wait = "120s"

[[gas-estimators]]
type = "Web3"

[[gas-estimators]]
type = "Alloy"

# HyperEVM solver registry — 2026-05-16 Phase 1:
# - Baseline RE-ADDED with HyperSwap V3 liquidity via
#   driver's [[liquidity.uniswap-v3]] block (Ormi subgraph confirmed live
#   with 2610 pools, current block, no indexing errors).
# - KyberSwap: VERIFIED LIVE; routes WHYPE↔USD₮0/USDe via Hybra-CL +
#   custom HL AMMs. Aggregator competition still primary.
# - Velora: dropped after API probe confirmed no chain-999 support.
# - OKX V6: does NOT support chain 999. Removed.
[[drivers]]
name = "baseline"
url = "http://driver/baseline"
address = "0x92B9bE5e96795E8630fDC61efb0e705E75b1A1B1"

[[drivers]]
name = "kyberswap"
url = "http://driver/kyberswap"
address = "0x92B9bE5e96795E8630fDC61efb0e705E75b1A1B1"

[fee-policies]

[database]
write-url = "%DB_WRITE_URL"
read-url = "%DB_READ_URL"

[order-quoting]
# Baseline (HyperSwap V3 direct) + KyberSwap (aggregator). Both used for
# quote estimation — driver auctions pick whichever returns better.
price-estimation-drivers = [
  { name = "baseline", url = "http://driver/baseline" },
  { name = "kyberswap", url = "http://driver/kyberswap" },
]

[price-estimation]
amount-to-estimate-prices-with = "1000000000000000"

[price-estimation.coin-gecko]
api-key = "%COINGECKO_API_KEY"
url = "https://api.coingecko.com/api/v3/simple/token_price"

[native-price-estimation]
# HyperEVM native-price estimation (Phase 1 — 2026-05-16):
#
# Tier 1: KyberSwap aggregator. Can price WHYPE↔any token via SELL-direction
# query after the kind=Sell fix in native_price/mod.rs. Most reliable
# single source today.
#
# Tier 2: baseline solver via Driver shim. Now backed by HyperSwap V3
# liquidity (driver.toml.tmpl [[liquidity.uniswap-v3]] block). Picks up
# tokens that KyberSwap can't (or rate-limits) but that have direct
# WHYPE/USD₮0 V3 pool depth. Two-tier fallback closes the gap that
# previously filtered orders as missing_native_price.
#
# CoinGecko still unavailable (no chain 999 in asset_platforms).
# Direct on-chain UniV3 TWAP estimator (apps/backend/crates/price-estimation/
# src/native/uniswap_v3.rs) could be wired here once we verify HyperSwap
# V3's init-code-hash on-chain — separate follow-up.
estimators = [
  [{ type = "Driver", name = "kyberswap", url = "http://driver/kyberswap" }],
  [{ type = "Driver", name = "baseline", url = "http://driver/baseline" }],
]

[native-price-estimation.cache]
max-age = "20m"
