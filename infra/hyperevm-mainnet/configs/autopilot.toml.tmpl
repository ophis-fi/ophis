# Ophis — HyperEVM mainnet (chain 999) autopilot config.
node-url = "${HYPEREVM_RPC_INTERNAL}"
simulation-node-url = "${HYPEREVM_RPC_INTERNAL}"

# Per-order wait while the run loop fetches a missing native (ETH-
# denominated) token price. Defaults to 0ns, which makes the auction
# filter any order whose token prices aren't already cached. The
# CoinGecko simple/token_price endpoint typically answers in 200-500ms
# so 5s is generous and covers a cold cache after restart.
native-price-timeout = "5s"

# HyperEVM Alchemy + public RPCs both reject block 0 lookups (Alchemy:
# -32001 "Unable to complete request"; public: -32603 "invalid block height: 0").
# Without skip-event-sync, the autopilot tries to backfill Settlement +
# CoW AMM + EthFlow events from genesis every block, logs "failed to
# fetch block 0" each time, and never marks essential maintenance done.
# We have no historical events to backfill (Settlement deployed at block
# 35173733, no prior CoW activity on HL), so starting from "latest" is
# correct. autopilot::run.rs:391 routes `skip_event_sync_start` to all
# three event indexers.
[ethflow]
skip-event-sync = true

[contracts]
settlement = "0x0864b65F1EFe752a699d119Ae0419E7331a8Bfce"
balances = "0x764fe4aa1ff493cf39931c7923c8ff5837596504"
signatures = "0xe4137bd2ecfdfb96d80629ec254dadec71bc498c"
native-token = "0x5555555555555555555555555555555555555555"
hooks = "0x29fcdbbdffd12fa7724b863991355b82ba8380e2"
balancer-v2-vault = "0xBA12222222228d8Ba445958a75a0704d566BF2C8"

[logging]
filter = "warn,autopilot=debug,shared=info,price_estimation=info"

[current-block]
poll-interval = "2s"  # OP block time

[run-loop]
solve-deadline = "20s"

[[gas-estimators]]
type = "Web3"

[[gas-estimators]]
type = "Alloy"

# HyperEVM solver registry — 2026-05-16 audit-driven cleanup:
# - Baseline REMOVED: returned NoSolutions on chain 999 (HyperSwap V2 doc
#   addresses had no bytecode). Re-add when V2/V3 liquidity wiring (task
#   #120) lands behind the observability stack (#118).
# - KyberSwap: VERIFIED LIVE; routes WHYPE↔USD₮0/USDe via Hybra-CL +
#   custom HL AMMs. Day-one primary liquidity source.
# - Velora (task #119): scaffolding incoming; will be the second
#   solver for real auction competition.
# - OKX V6: does NOT support chain 999 (free-tier probe returned empty
#   chain list). Removed.
[[drivers]]
name = "kyberswap"
url = "http://driver/kyberswap"
address = "0xFB308397267878228f7761311DBD6Bc6FCa1bB5a"

[fee-policies]

[database]
write-url = "%DB_WRITE_URL"
read-url = "%DB_READ_URL"

[order-quoting]
# KyberSwap is the only verified-working route source on HyperEVM at
# day-one. Baseline driver entry dropped 2026-05-16; will be replaced by
# the Velora aggregator (task #119) once landed. OKX dropped — not
# available on chain 999.
price-estimation-drivers = [
  { name = "kyberswap", url = "http://driver/kyberswap" },
]

[price-estimation]
amount-to-estimate-prices-with = "1000000000000000"

[price-estimation.coin-gecko]
api-key = "%COINGECKO_API_KEY"
url = "https://api.coingecko.com/api/v3/simple/token_price"

[native-price-estimation]
# HyperEVM-specific: neither CoinGecko (no chain 999 in asset platforms,
# per /tmp/hyperevm-research.md) nor Uniswap V3 (HyperSwap V3 factory +
# init-code-hash addresses not yet verified) can compute native prices
# today. Using the `Driver` shim — points at baseline — bypasses the
# init-time chain-check that would otherwise panic the orderbook at
# boot (same workaround we shipped for MegaETH). At runtime baseline
# can't compute prices either, so orders requiring a native price for
# fee accounting are filtered with missing_native_price.
#
# Follow-up: extend the UniswapV3 estimator from PR #43 with the
# HyperSwap V3 factory + init-code-hash once we verify them on-chain
# (research flagged these as "needs probe" — see hyperevm-research.md
# §"Critical unknowns").
# KyberSwap aggregator first (can price WHYPE↔any token via SELL-direction
# query after the kind=Sell fix in native_price/mod.rs), baseline as
# fallback. Without kyberswap, the autopilot filters every order with
# a non-native buy_token as missing_native_price, even though the
# orderbook can serve a quote — because the autopilot uses its own
# native-price estimator instance that wasn't wired to kyberswap.
estimators = [
  [{ type = "Driver", name = "kyberswap", url = "http://driver/kyberswap" }],
]

[native-price-estimation.cache]
max-age = "20m"
