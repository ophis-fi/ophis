# eRPC multi-provider proxy for HyperEVM mainnet (chain 999).
#
# Reliability map (probed 2026-05-16, re-probed 2026-05-18):
#   PurroofGroup       10/10 on isSolver eth_call, 461 req/min throughput
#   HL official        10/10 (rpc.hyperliquid.xyz/evm), 100 req/min/IP cap
#   Hypurrscan         10/10 chain-id + eth_call clean (AWS Tokyo, HL-native)
#   HyperLend          DROPPED 2026-05-18 — chronic ErrEndpointCapacityExceeded
#                      under steady-state load. Recovery is provider-side; revisit
#                      after they raise public-tier limits.
#   dRPC               11/20 = 55% (flake "intrinsic gas too high"). EXCLUDED.
#   1RPC               finalized-tag silently stuck (drift +26 blocks). EXCLUDED.
#   Alchemy free tier  monthly cap EXHAUSTED 2026-05-15. EXCLUDED.
#   Bloxroute/Thirdweb MEV-adjacent commercial RPC; solver eth_call leaks
#                      trade intent. EXCLUDED — Bloxroute standard applied uniformly.
#   Pocket Network     "decentralized P2P" misleading — Ophis's free-tier app
#                      currently maps to a SINGLE Hetzner canary node, not a
#                      multi-node pool. EXCLUDED until app pins a known relay set.
#   OnFinality         429 rate-limited on public tier; empty eth_call. EXCLUDED.
#
# Strategy (replace-not-expand; sharp-edges + adversarial review 2026-05-18):
#  - Keep N=3 upstreams for the 2-of-3 consensus failsafe. The audit-required
#    fork-view-poisoning guarantee is "attacker needs to compromise ≥2-of-N
#    upstreams"; expanding N to 8 silently weakens that to "attacker needs
#    ≥2-of-8" because eRPC's `maxParticipants: 3` does RANDOM sampling. Sybil-2
#    attacker → 10.7% per-request poison rate with N=8 (was 0% with N=3).
#  - Hypurrscan replaces HyperLend as the 3rd upstream. AWS-Tokyo backbone
#    (distinct failure domain from purroof/Vultr and official/AWS-CloudFront),
#    HL-native operator, no MEV-searcher overlap.
#  - integrity.enforceHighestBlock=true: only route eth_call to upstreams that
#    have caught up to the requested block (fixes "upstream does not have
#    requested block yet" the kyberswap solver gas-sim hits on HL's fast 1-2s
#    block times).
#  - statePollerDebounce=1s: keep per-upstream tip-block view fresh.
#  - NO cache layer. ttl:0 on "finalized" methods would bypass the consensus
#    invariant, and HL "finalized" empirically drifts by up to 26 blocks across
#    providers — a single bad consensus round would persist forever in cache.
#
# Endpoint exposed: http://rpc-proxy:4000/main/evm/999

logLevel: info

projects:
  - id: main

    # Network-level integrity: ensure eth_call+similar are routed to upstreams
    # that have the requested block. Without this, fast-chain HL (1-2s blocks)
    # surfaces "upstream does not have the requested block yet" errors when
    # the simulator requests state at the autopilot's just-observed block but
    # the routed upstream hasn't seen it yet.
    networks:
      - architecture: evm
        evm:
          chainId: 999
          integrity:
            enforceHighestBlock: true
            enforceNonNullTaggedBlocks: true
        # Consensus failsafe: defeats fork-view-poisoning on state-reads.
        # Each of our 3 free upstreams is unauthenticated HTTPS — a hostile
        # provider (or MITM via CA compromise / DNS hijack) could otherwise
        # serve a self-consistent fork that the autopilot signs settlements
        # against. With 2-of-3 agreement on the methods that drive solver
        # behavior, a single hostile upstream can't influence outcomes.
        failsafe:
          # Critical reads: state-dependent calls that gate solver behavior
          # and settlement validity. Require 2-of-3 agreement OR fail.
          # Consensus-protected methods. eth_getTransactionByHash added 2026-05-18
          # per Codex Cyber + silent-failure-hunter review — response includes
          # forkable fields (blockHash, blockNumber); a hostile upstream could
          # otherwise mislead the autopilot's max-settlement-transaction-wait
          # watcher via the non-consensus "*" fallback path.
          - matchMethod: "eth_call|eth_getBlockByNumber|eth_getBlockByHash|eth_getLogs|eth_getTransactionReceipt|eth_getTransactionByHash"
            timeout:
              duration: 10s
            consensus:
              maxParticipants: 3
              agreementThreshold: 2
              disputeBehavior: returnError
              # Codex review 2026-05-16 (H3 follow-up): the obvious default
              # `acceptMostCommonValidResult` here SILENTLY collapses to
              # single-upstream trust when 2/3 providers fail to answer —
              # the surviving 1 provider can then poison critical reads
              # because "most common" = "whatever the only respondent said".
              # `returnError` is the only fail-closed behavior consistent
              # with H3's threat model (defeats fork-view-poisoning even
              # under high provider failure load). Trade-off: occasional
              # transient failures during multi-provider outages bubble up
              # to the autopilot/driver retry layer, which is correct.
              lowParticipantsBehavior: returnError
              preferNonEmpty: true
              ignoreFields:
                # `timestamp` is the obvious diverge field; some HL providers
                # also report `mixHash`/`difficulty` as 0 vs absent.
                eth_getBlockByNumber: ["timestamp"]
                eth_getBlockByHash: ["timestamp"]
              punishMisbehavior:
                disputeThreshold: 5
                disputeWindow: 10m
                sitOutPenalty: 30m
          # All other methods (block-stream poll, balance polls) go through
          # the default upstream-level failsafe with retry — no consensus
          # because they're either non-security-critical OR (for nonce reads
          # + tx submission) handled by pinning to a single upstream in the
          # driver config's [[submission.mempool]] block.
          - matchMethod: "*"
            timeout:
              duration: 10s
            retry:
              maxAttempts: 3
              delay: 150ms
              backoffMaxDelay: 1s
              backoffFactor: 1.5
              jitter: 50ms

    # Keep each upstream's tip-block tracking aligned with HL's block time
    # (1-2s for small blocks).
    upstreamDefaults:
      evm:
        statePollerInterval: 5s
        statePollerDebounce: 1s

    upstreams:
      - id: purroof-hl
        endpoint: https://rpc.purroofgroup.com
        failsafe:
          - matchMethod: "*"
            timeout:
              duration: 8s
            retry:
              maxAttempts: 3
              delay: 150ms
              backoffMaxDelay: 1s
              backoffFactor: 1.5
              jitter: 50ms

      - id: official-hl
        endpoint: https://rpc.hyperliquid.xyz/evm
        failsafe:
          - matchMethod: "*"
            timeout:
              duration: 8s
            # Retry budget matched to purroof-hl (2026-05-18 review finding):
            # asymmetric budgets caused autopilot bootstrap-burst exhaustion on
            # the slower two upstreams while purroof's 3-attempt budget held.
            # Backoff + jitter prevent synchronized retry storms across the
            # autopilot + driver + orderbook consumers of this proxy.
            retry:
              maxAttempts: 3
              delay: 200ms
              backoffMaxDelay: 1s
              backoffFactor: 1.5
              jitter: 50ms

      - id: hypurrscan-hl
        endpoint: https://rpc.hypurrscan.io
        failsafe:
          - matchMethod: "*"
            timeout:
              duration: 8s
            # See official-hl comment — budgets aligned across all 3 upstreams.
            retry:
              maxAttempts: 3
              delay: 200ms
              backoffMaxDelay: 1s
              backoffFactor: 1.5
              jitter: 50ms
