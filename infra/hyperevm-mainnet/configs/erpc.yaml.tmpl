# eRPC multi-provider proxy for HyperEVM mainnet (chain 999).
#
# Why: Alchemy free tier returns HTTP 429 under the driver+autopilot's
# combined polling load (block_stream every 1s + per-quote fee_history +
# per-tx eth_call). eRPC fans out requests across 5 free providers with
# automatic failover, retry, and re-org aware caching so we stay under
# each provider's rate limit.
#
# Endpoint exposed to other services: http://rpc-proxy:4000/main/evm/999
# (eRPC default port; project=`main`, chain=999 auto-detected).
#
# Providers (all verified live 2026-05-15 returning chain_id 0x3e7):
#   - Alchemy             (paid potential, currently 429-throttled)
#   - dRPC                (free tier, multi-region)
#   - 1RPC                (free tier, single endpoint)
#   - PurroofGroup        (community HL public RPC)
#   - HyperLend           (DeFi-app-operated public RPC)
#   - Hyperliquid public  (rpc.hyperliquid.xyz/evm, 100 req/min/IP — last-resort)

logLevel: info

projects:
  - id: main
    upstreams:
      # Alchemy first — best latency when not throttled. eRPC will mark it
      # cordoned on repeated 429s and route around it automatically.
      - id: alchemy-hl
        endpoint: https://hyperliquid-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
        failsafe:
          - matchMethod: "*"
            timeout:
              duration: 8s
            retry:
              maxAttempts: 2
              delay: 200ms
              backoffMaxDelay: 1s
              backoffFactor: 1.5

      # dRPC — public HL endpoint, generous free tier.
      - id: drpc-hl
        endpoint: https://hyperliquid.drpc.org
        failsafe:
          - matchMethod: "*"
            timeout:
              duration: 10s
            retry:
              maxAttempts: 2
              delay: 200ms

      # 1RPC — privacy-focused free tier.
      - id: onerpc-hl
        endpoint: https://1rpc.io/hyperliquid
        failsafe:
          - matchMethod: "*"
            timeout:
              duration: 10s

      # PurroofGroup community RPC.
      - id: purroof-hl
        endpoint: https://rpc.purroofgroup.com
        failsafe:
          - matchMethod: "*"
            timeout:
              duration: 10s

      # HyperLend RPC (DeFi-app-operated).
      - id: hyperlend-hl
        endpoint: https://rpc.hyperlend.finance
        failsafe:
          - matchMethod: "*"
            timeout:
              duration: 10s

      # Hyperliquid public — last-resort fallback (100 req/min/IP cap).
      - id: public-hl
        endpoint: https://rpc.hyperliquid.xyz/evm
        failsafe:
          - matchMethod: "*"
            timeout:
              duration: 10s
