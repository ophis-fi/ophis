# Ophis — HyperEVM mainnet (chain 999) orderbook config.
# Audit MEDIUM-6 (2026-05-17): flipped from `true` → `false`. The `true`
# default skipped EIP-1271 validation against the SCW's *current* state at
# order-creation time. Combined with EthFlow's isValidSignature (which
# returns MAGICVALUE based purely on storage state), a malicious SCW could
# race between createOrder and settle: orderbook surfaces an "approved"
# quote that may not be settleable, leading to wasted auction cycles. CoW
# upstream production uses `false` everywhere — we now match. Trade-off:
# extra ~50-100ms latency per SCW order creation; worth it for the
# correctness guarantee.
eip1271-skip-creation-validation = false
bind-address = "0.0.0.0:80"

[shared]
node-url = "${HYPEREVM_RPC_INTERNAL}"
simulation-node-url = "${HYPEREVM_RPC_INTERNAL}"

# Override every contract address — HyperEVM mainnet (chain 999) needs explicit
# Ophis-deployed addresses since upstream's contracts registry doesn't include
# our deployments here. From deploy-mainnet-all.sh on 2026-05-15.
[shared.contracts]
settlement = "0x0864b65F1EFe752a699d119Ae0419E7331a8Bfce"
balances = "0x764fe4aa1ff493cf39931c7923c8ff5837596504"
signatures = "0xe4137bd2ecfdfb96d80629ec254dadec71bc498c"
native-token = "0x5555555555555555555555555555555555555555"
hooks = "0x29fcdbbdffd12fa7724b863991355b82ba8380e2"
# Balancer V2 Vault: canonical cross-chain address used as a flash-loan source
# for solver simulation. The Vault is deployed on OP at the same address.
balancer-v2-vault = "0xBA12222222228d8Ba445958a75a0704d566BF2C8"

[database]
write-url = "%DB_WRITE_URL"
read-url = "%DB_READ_URL"

[native-price-estimation]
# HyperEVM native-price estimation (Phase 1 — 2026-05-16):
#
# Tier 1: KyberSwap aggregator. Most reliable single source today —
# routes WHYPE↔any token via SELL-direction queries.
#
# Tier 2: baseline solver via Driver shim. Backed by HyperSwap V3
# liquidity (driver.toml.tmpl [[liquidity.uniswap-v3]] block — Ormi
# subgraph, ~2610 indexed pools). Picks up tokens with deep V3 pool
# depth that KyberSwap can't (or rate-limits).
#
# CoinGecko still unavailable (no chain 999 in asset_platforms).
# Direct on-chain UniV3 TWAP estimator could land here as a Tier 3
# follow-up once we verify HyperSwap V3's init-code-hash.
estimators = [
  [{ type = "Driver", name = "kyberswap", url = "http://driver/kyberswap" }],
  [{ type = "Driver", name = "baseline", url = "http://driver/baseline" }],
]

[order-quoting]
# Baseline (HyperSwap V3 direct) + KyberSwap (aggregator) — both used
# for orderbook-side quote estimation. Auction picks the winner.
price-estimation-drivers = [
  { name = "baseline", url = "http://driver/baseline" },
  { name = "kyberswap", url = "http://driver/kyberswap" },
]

[price-estimation]
amount-to-estimate-prices-with = "1000000000000000"  # 0.001 ETH

# 2026-05-17: balance-override config for WHYPE so the trade verifier
# (`price_estimation::trade_verifier`) can use Spardose's balance-injection
# trick during quote simulation. Without this, the verifier falls back to
# the trader's REAL balance and the quote comes back `verified: false`.
# Today's incident: native HYPE holders using the EthFlow path get
# `verified: false` quotes that are still valid, but the orderbook's
# negative-cache for unverified quotes interacts badly with KyberSwap's
# rate-limited responses — over time, transient KyberSwap failures get
# cached as "no liquidity" and the orderbook serves the cache instead of
# retrying. Spardose-mocked balances let verification succeed cleanly,
# avoiding the unverified-quote cache path entirely.
#
# WHYPE at 0x5555…5555 is a canonical WETH9 clone — verified on-chain
# (balanceOf is at storage slot 3, the WETH9 standard).
[price-estimation.balance-overrides.token-overrides.0x5555555555555555555555555555555555555555]
type = "SolidityMapping"
target_contract = "0x5555555555555555555555555555555555555555"
map_slot = "0x3"

# CoinGecko config. The coin-gecko sub-block belongs under [price-estimation],
# not [native-price-estimation], even though only the native estimator uses it.
[price-estimation.coin-gecko]
# CoinGecko Demo-tier key (free, signup at coingecko.com/api/pricing).
# Read from container env via CoW's %VAR_NAME interpolation. The COW
# code was patched to use x-cg-demo-api-key header for Demo keys (see
# coingecko.rs constant AUTHORIZATION).
api-key = "%COINGECKO_API_KEY"
url = "https://api.coingecko.com/api/v3/simple/token_price"
