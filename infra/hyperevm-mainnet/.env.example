# infra/hyperevm-mainnet/.env — Ophis HyperEVM mainnet secrets.
# COPY this file to .env, fill in the secrets, NEVER COMMIT the populated form.
# .gitignore already excludes infra/hyperevm-mainnet/.env.
#
# After copying, chmod 600 .env — render-configs.sh enforces this on every
# deploy but the initial copy is on the operator. The Keychain entries
# listed below are the authoritative source; this .env is a deploy-time
# mirror.

# ── Database ──────────────────────────────────────────────────────────────
# Pick a strong random password (32+ chars). Generate via:
#   openssl rand -base64 32
POSTGRES_USER=ophis
POSTGRES_PASSWORD=
POSTGRES_DB=ophis
DB_WRITE_URL=postgresql://ophis:${POSTGRES_PASSWORD}@db:5432/ophis
DB_READ_URL=postgresql://ophis:${POSTGRES_PASSWORD}@db:5432/ophis

# ── Chain RPC ─────────────────────────────────────────────────────────────
# Alchemy HyperEVM mainnet endpoint. The public RPC (rpc.hyperliquid.xyz/evm)
# caps at 100 req/min/IP which the driver would blow through quickly. Alchemy
# free tier is 30M CU/month — plenty for early launch volume. Retrieve key:
#   security find-generic-password -s alchemy-api-key -w
ALCHEMY_API_KEY=
HYPEREVM_MAINNET_RPC=https://hyperliquid-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# ── Driver-submitter private key ──────────────────────────────────────────
# Corresponds to on-chain address 0xFB308397267878228f7761311DBD6Bc6FCa1bB5a
# (post-rotation EOA, same as OP + MegaETH). Must be allowlisted on the
# Ophis AllowList for chain 999 via deploy-mainnet-all.sh Step 3.
#
# Pre-deploy: this EOA must also be opted into HyperEVM big blocks via
# infra/hyperevm/opt-in-big-blocks.py — settle() exceeds the 3M-gas
# small-block limit so without opt-in the tx never lands.
#
# 32-byte hex, 0x-prefixed. Retrieve from macOS Keychain via:
#   security find-generic-password -s ophis-driver-submitter-2026-05-14 -w
OPHIS_DRIVER_SUBMITTER_KEY=

# ── OKX V6 aggregator: NOT USED on chain 999 ──────────────────────────────
# OKX does not yet support HyperEVM (verified 2026-05-15). When they do,
# re-add OKX_PROJECT_ID / OKX_API_KEY / OKX_SECRET_KEY / OKX_PASSPHRASE
# from infra/optimism-mainnet/.env.example and uncomment the okx-solver
# service in docker-compose.yml.
