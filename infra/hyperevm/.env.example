# infra/hyperevm/.env — Greg Phase 3b Hyperliquid HyperEVM environment
# Copy to infra/hyperevm/.env and fill in. NEVER commit infra/hyperevm/.env.

# Postgres (matches docker-compose service)
POSTGRES_USER=greg
POSTGRES_PASSWORD=123
POSTGRES_DB=postgres
DB_WRITE_URL=postgresql://greg:123@db:5432/postgres
DB_READ_URL=postgresql://greg:123@db:5432/postgres

# --- Networks ---
HYPEREVM_TESTNET_RPC=https://rpc.hyperliquid-testnet.xyz/evm
HYPEREVM_TESTNET_CHAIN_ID=998
HYPEREVM_TESTNET_EXPLORER=https://testnet.hyperevmscan.io

HYPEREVM_MAINNET_RPC=https://rpc.hyperliquid.xyz/evm
HYPEREVM_MAINNET_CHAIN_ID=999
HYPEREVM_MAINNET_EXPLORER=https://hyperevmscan.io

# --- Deployer EOA (reused from MegaETH; Keychain greg-megaeth-deployer) ---
