# infra/unichain-mainnet/.env.example — Ophis Unichain mainnet (chain 130) secrets.
# COPY this file to .env, fill in the secrets, NEVER COMMIT the populated form.
# .gitignore already excludes infra/unichain-mainnet/.env.
#
# After copying: chmod 600 .env
# render-configs.sh enforces this on every deploy, but do it at copy time.
#
# NOTE: the driver-submitter PK lives at /Users/ophis-driver/.config/submitter.key
# (Tier 1 PK isolation — same as OP stack). Do NOT put it in this file.

# ── Database ──────────────────────────────────────────────────────────────
# Use a DIFFERENT DB password from the OP stack — separate Postgres instance.
POSTGRES_USER=ophis
POSTGRES_PASSWORD=
POSTGRES_DB=ophis
DB_WRITE_URL=postgresql://ophis:${POSTGRES_PASSWORD}@db:5432/ophis
DB_READ_URL=postgresql://ophis:${POSTGRES_PASSWORD}@db:5432/ophis

# ── Chain RPC ─────────────────────────────────────────────────────────────
# UNICHAIN_MAINNET_RPC: direct RPC URL substituted into solver TOML templates
# (okx, kyberswap, velora, baseline configs). The eRPC proxy uses its own
# 3 hardcoded upstreams and does NOT read this var.
UNICHAIN_MAINNET_RPC=https://mainnet.unichain.org

# UNICHAIN_RPC_INTERNAL: optional bypass of the eRPC 2-of-3 consensus proxy.
# When set, ALL chain-reading services point at this single URL instead of
# http://rpc-proxy:4000/main/evm/130. LEAVE EMPTY in normal operation.
# render-configs.sh + compose-up.sh REFUSE to proceed unless
# ALLOW_RPC_BYPASS=1 is also set (fail-closed guard mirrors OP pattern).
UNICHAIN_RPC_INTERNAL=

# ── Driver-submitter private key ──────────────────────────────────────────
# Tier 1 PK isolation: PK lives at /Users/ophis-driver/.config/submitter.key.
# render-configs.sh reads it via sudo. LEAVE EMPTY here.
OPHIS_DRIVER_SUBMITTER_KEY=

# ── OKX aggregator solver credentials ─────────────────────────────────────
# The OKX API key can be reused from the OP stack — OKX's chain-id field
# in the config template differentiates Unichain (130) from OP (10) requests.
# Create at https://web3.okx.com/build → API keys.
OKX_PROJECT_ID=
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ── Distributed tracing ───────────────────────────────────────────────────
# Set to http://jaeger:4317 to enable OTLP/gRPC tracing. Leave empty to disable.
# Jaeger UI available at http://127.0.0.1:16687 when enabled.
TRACING_COLLECTOR_ENDPOINT=

# ── Observability (Prometheus + Alertmanager → Telegram) ─────────────────
# PREFERRED source: macOS Keychain (service=ophis-telegram-bot).
# Leave EMPTY here if using Keychain — render-configs.sh checks Keychain first.
TELEGRAM_BOT_TOKEN=

# ── CoinGecko (native-price oracle for autopilot + orderbook) ─────────────
# Required at startup. Get a free Demo key at coingecko.com/en/api/pricing.
# Unichain is supported by CoinGecko (in asset_platforms list).
COINGECKO_API_KEY=

# ── Inter-service auth (F7 hardening) ────────────────────────────────────
# Shared Bearer token between autopilot ↔ driver.
# Source from Keychain: security find-generic-password -s ophis-inter-service-auth-token -w
OPHIS_INTER_SERVICE_AUTH_TOKEN=

# ══ DEPLOY / LEDGER CEREMONY ONLY (deploy/deploy-mainnet-all.sh; NOT read by the stack) ══
# Fill these before the WS3 ceremony. See deploy/ and FILL-IN-AFTER-DEPLOY.md.

# ── Protocol Safe (Clement) ───────────────────────────────────────────────
# The 2-of-3 Ophis protocol Safe deployed ON UNICHAIN (130). Takes ownership +
# manager of AllowListAuthentication at the end of the ceremony. Create at
# app.safe.global on Unichain (or confirm an existing one).
OPHIS_PROTOCOL_SAFE_UNICHAIN_MAINNET=
# Its 3 owner addresses (comma/space-separated). If set, the ceremony HARD-asserts
# every one is present (rejects a wrong-but-valid 2-of-3 Safe). Strongly recommended.
OPHIS_SAFE_EXPECTED_OWNERS=

# ── Bytecode pins (optional, ToB F2) ──────────────────────────────────────
# Expected runtime codehashes of the immutable-free contracts, computed at ceremony
# prep from the OP/MegaETH deployed equivalents (cast codehash <op-addr>). If set,
# the step-2.5 gate machine-asserts them instead of relying on the human ToB diff.
OPHIS_EXPECTED_CODEHASH_AUTHIMPL=
OPHIS_EXPECTED_CODEHASH_BALANCES=
OPHIS_EXPECTED_CODEHASH_SIGNATURES=

# ── Auto-populated by the ceremony (do NOT fill by hand) ───────────────────
# deploy-mainnet-all.sh appends the deployed addresses here after a successful run:
#   OPHIS_AUTH_UNICHAIN / OPHIS_AUTH_IMPLEMENTATION_UNICHAIN / OPHIS_SETTLEMENT_UNICHAIN
#   OPHIS_VAULT_RELAYER_UNICHAIN / OPHIS_BALANCES_UNICHAIN / OPHIS_SIGNATURES_UNICHAIN
#   OPHIS_HOOKS_TRAMPOLINE_UNICHAIN
