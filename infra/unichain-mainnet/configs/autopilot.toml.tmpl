  [
    { type = "UniswapV3", factory = "0x1F98431c8aD98523631AE4a59f267346ea31F984", init-code-hash = "0xe34f199b19b2b4f47f68442619d555527d244f78a3297ea89325f843f87b8b54" },
    { type = "CoinGecko" },
  ],
]

[native-price-estimation.cache]
max-age = "20m"
