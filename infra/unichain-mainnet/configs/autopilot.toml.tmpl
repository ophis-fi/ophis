# Ophis — Unichain mainnet (chain 130) autopilot config.
#
# TEMPLATE FILE. Render with envsubst at deploy time:
#   ./render-configs.sh
#
# UNICHAIN_RPC_INTERNAL defaults to the eRPC proxy path in docker-compose.yml;
# it is only set in .env when deliberately bypassing consensus (e.g. for
# failure-domain tests).
# node-url is a plain Url field (no %ENV deserializer) → must be a literal URL;
# an empty ${UNICHAIN_RPC_INTERNAL} fails TOML parse. Hardcode the eRPC proxy,
# same as the OP stack's canonical autopilot.toml. The driver keeps the
# UNICHAIN_RPC_INTERNAL single-provider bypass via its ETHRPC env.
node-url = "http://rpc-proxy:4000/main/evm/130"
simulation-node-url = "http://rpc-proxy:4000/main/evm/130"

# Per-order wait while the run loop fetches a missing native (ETH-denominated)
# token price. CoinGecko simple/token_price typically answers in 200-500ms;
# 5s is generous and covers a cold cache after restart.
native-price-timeout = "5s"

# NOTE: skip-event-sync lives under the [ethflow] section in this backend's
# config schema (configs/src/autopilot/ethflow.rs), NOT at the top level —
# see [ethflow] below.
#
# OPERATIONAL INVARIANT (self-node retention): the self-node prunes receipts/logs
# to ~24h (86400 blocks). The autopilot indexes settlement logs forward from the
# GPv2 deploy block and must not fall >24h behind, or the self-node can no longer
# serve the gap's logs. eRPC's two public read legs DO serve historical eth_getLogs,
# so a >24h autopilot outage still recovers via 2-of-3 consensus from the public
# legs (not the self-node). Self-node-only RTO is ~24h; longer gaps lean on the
# public legs. Same recovery model as the OP stack.

[contracts]
settlement = "0x108A678716e5E1776036eF044CAB7064226F714E"
balances = "0x78799F98276efba1EdeeD32eae03a3fd8Cdfec3A"
signatures = "0x5f315A204E7971fC29a66fef3a5773f6B0202fac"
native-token = "0x4200000000000000000000000000000000000006"  # WETH (OP Stack predeploy on Unichain)
hooks = "0x2FbB1e41fF4f9b707E4428EEC7F5AFAaC5D60810"
balancer-v2-vault = "0xBA12222222228d8Ba445958a75a0704d566BF2C8"  # canonical cross-chain

[ethflow]
# skip-event-sync = true: the sovereign Unichain settlement is NOT in CoW's
# canonical contracts registry (same reasoning as HL/chain-999). Without it the
# autopilot backfills Settlement events from genesis and rejects block-0 lookups.
# Start from "latest" and index forward. (This field is parsed into the ethflow
# config — configs/src/autopilot/ethflow.rs — hence its placement here.)
skip-event-sync = true
# EthFlow DEPLOYED 2026-06-29 (CoWSwapEthFlow, native-ETH sells). Constructor-wired
# to Settlement 0x108A6787…F714E + WETH 0x4200…0006; WETH→vaultRelayer(0xaB29E2a8…)
# allowance = MAX; runtime byte-identical to OP's EthFlow. Reviewed Codex gpt-5.5 +
# Trail of Bits + Verity (settlement leg). NOTE: under skip-event-sync=true the
# autopilot indexes EthFlow from LATEST (indexing-start is a no-op — ethflow_events.rs:170);
# orders must be placed AFTER an autopilot restart to be indexed (no backfill).
contracts = ["0x38C03729153BCCF6a281DaF41D7C6a14C543F1D7"]
indexing-start = 51995740

[logging]
filter = "warn,autopilot=debug,shared=info,price_estimation=info"

[current-block]
poll-interval = "1s"  # Unichain block time (~1s)

[run-loop]
solve-deadline = "20s"

