# Ophis — Unichain mainnet (chain 130) OpenOcean V4 aggregator solver config.
#
# TEMPLATE FILE. Render with envsubst at deploy time:
#   ./render-configs.sh
#
# ENABLED on Unichain (2026-06-30). OpenOcean V4 serves chain 130. The
# OpenOceanExchangeProxy 0x6352a56caadC4F1E25CD6c75970Fa768A3304e64 (router
# `tx.to` == ERC-20 spender) is in BOTH the solver allowlist
# (dex::openocean::OPENOCEAN_ROUTER_ALLOWLIST) AND the driver allowlist
# (custom_allowlist::UNICHAIN_MAINNET). The SELL output reports OpenOcean's
# guaranteed data.minOutAmount (the slippage floor) — the #726 fix. Keyless:
# the V4 quote/swap endpoints need no API key.

node-url = "${UNICHAIN_MAINNET_RPC}"

# Unichain's 0x4200..06 wrapped-native predeploy stores balances at mapping
# slot 0 (WETH98-style), NOT WETH9's slot 3 (the binary default, correct on
# OP). The eth-flow sim balance override writes to this slot; a wrong slot
# silently grants nothing and fail-closes every native-ETH sell (2026-07-18
# incident). Verified on-chain 2026-07-18.
wrapped-native-balance-slot = 0

# Ophis-fork settlement on Unichain.
settlement = "0x108A678716e5E1776036eF044CAB7064226F714E"

[dex]
chain-id = "130"

# OpenOcean referrer address (optional — fee attribution only, NEVER the funds
# path). Unset = no referral fee. To set one without committing a value, add
# ${OPENOCEAN_REFERRER} to the envsubst allowlist in render-configs.sh and
# uncomment:
# referrer = "${OPENOCEAN_REFERRER}"
