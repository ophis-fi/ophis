# Ophis — Unichain mainnet (chain 130) Velora aggregator solver config.
#
# TEMPLATE FILE. Render with envsubst at deploy time:
#   ./render-configs.sh
#
# TODO verify Unichain support: Velora (formerly ParaSwap) Augustus V6.2 is
# confirmed available on Unichain via api.paraswap.io (network 130) per
# Velora developer documentation. However, the CoW solver crate's
# dex::velora::VELORA_ROUTER_ALLOWLIST must include Unichain's Augustus V6.2
# contract address before this service can route orders. The velora-solver
# service is commented out in docker-compose.yml pending that allowlist patch.
#
# When re-enabling: verify the Augustus V6.2 address on Unichain (the canonical
# CREATE2-deterministic address 0x6a000f20005980200259b80c5102003040001068
# may apply — confirm via uniscan.xyz before adding to the allowlist).

node-url = "${UNICHAIN_MAINNET_RPC}"

# Ophis-fork settlement on Unichain. Fill after Phase-1 Ledger ceremony.
settlement = "0x108A678716e5E1776036eF044CAB7064226F714E"

[dex]
chain-id = "130"

partner = "ophis"

# partner-address and partner-fee-bps deliberately commented out — same
# double-charging concern as OP velora.toml.tmpl. CIP-75 handles partner
# fees at the protocol layer.
# partner-address = "0x858f0F5eE954846D47155F5203c04aF1819eCeF8"
# partner-fee-bps = 25
