# The integrator referral code that earns the 8-12% rev-share (also accepted via ?ref= in the URL).
VITE_OPHIS_REFERRAL_CODE=
# Rebate indexer base URL. The app pings GET <base>/tier/<safe> to register the Safe in tracked_wallets
# so the owner-scoped fetcher indexes its trades (otherwise the rebate is never credited).
# VERIFY this against apps/mcp-server's configured indexer URL before deploying.
VITE_OPHIS_REBATE_API=https://rebates.ophis.fi
