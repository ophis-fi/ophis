{
  "name": "@ophis/rebate-indexer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "DOCKER_HOST=${DOCKER_HOST:-unix:///Users/scep/.colima/default/docker.sock} TESTCONTAINERS_RYUK_DISABLED=${TESTCONTAINERS_RYUK_DISABLED:-true} TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE=${TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE:-/var/run/docker.sock} vitest run tests/integration.test.ts",
    "test:e2e": "vitest run tests/e2e",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "cli": "tsx src/cli.ts",
    "scan": "tsx src/scan/cli.ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@safe-global/api-kit": "^2.5.0",
    "@safe-global/protocol-kit": "^5.0.0",
    "@safe-global/safe-deployments": "^1.37.0",
    "@safe-global/types-kit": "^1.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "node-cron": "^4.2.1",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "tsx": "^4.19.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.13.0",
    "@types/node": "^22.5.0",
    "drizzle-kit": "^0.31.10",
    "fast-check": "^3.22.0",
    "msw": "^2.6.0",
    "pino-pretty": "^11.3.0",
    "testcontainers": "^10.13.0",
    "typescript": "^5.5.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
