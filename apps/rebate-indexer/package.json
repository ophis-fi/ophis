    "fastify": "^5.0.0",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "tsx": "^4.19.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.28.0",
    "fast-check": "^3.22.0",
