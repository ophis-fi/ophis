---
/**
 * Spark field — brighter, randomly-drifting 4-point star motes layered on top
 * of the soft Particles starfield for extra liveliness.
 *
 * Same discipline as Particles.astro: rendered ONCE at build time into N
 * positioned <span>s — pure HTML + CSS, NO client JavaScript and NO Astro
 * island hydration. The inline `style` attributes only carry CSS custom
 * properties (allowed by `style-src 'unsafe-inline'`), so the CSP *script*
 * hash set in public/_headers stays untouched and the LHCI Total-Blocking-Time
 * budget is unaffected. All motion lives in global.css and is disabled under
 * prefers-reduced-motion.
 *
 * Unlike Particles (soft dots drifting straight up), sparks drift along a
 * random 2D vector (--dx/--dy) with a slight rotation, giving the "randomly
 * moving sparks" feel. Positions/timing come from a seeded deterministic PRNG
 * (different seed from Particles) so every build emits byte-identical markup.
 */

const COUNT = 20

// Mulberry32 — tiny deterministic PRNG. Fixed seed => identical sequence on
// every build, so the markup never drifts between CI and local.
function makeRng(seed: number): () => number {
  let a = seed >>> 0
  return () => {
    a = (a + 0x6d2b79f5) | 0
    let t = Math.imul(a ^ (a >>> 15), 1 | a)
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296
  }
}

const rng = makeRng(0x1f83d9ab)

const sparks = Array.from({ length: COUNT }, () => {
  const dur = +(6 + rng() * 11).toFixed(1) // 6–17s drift
  const angle = rng() * Math.PI * 2 // random 2D direction
  const dist = 14 + rng() * 30 // 14–44px of travel
  return {
    left: +(rng() * 100).toFixed(2),
    top: +(rng() * 100).toFixed(2),
    size: +(6 + rng() * 9).toFixed(1), // 6–15px star
    dx: +(Math.cos(angle) * dist).toFixed(1),
    dy: +(Math.sin(angle) * dist).toFixed(1),
    rot: +((rng() - 0.5) * 70).toFixed(1), // -35..35deg
    dur,
    delay: +(-rng() * dur).toFixed(1), // negative delay desyncs start frames
    tdur: +(2.5 + rng() * 4).toFixed(1), // 2.5–6.5s twinkle period
    op: +(0.35 + rng() * 0.5).toFixed(2), // peak brightness
    hue: rng() > 0.45 ? 'saffron' : 'violet',
  }
})
---

<div class="sparks" aria-hidden="true">
  {
    sparks.map((s) => (
      <span
        class={`spark spark--${s.hue}`}
        style={`left:${s.left}%;top:${s.top}%;width:${s.size}px;height:${s.size}px;--dx:${s.dx}px;--dy:${s.dy}px;--rot:${s.rot}deg;--dur:${s.dur}s;--delay:${s.delay}s;--tdur:${s.tdur}s;--op:${s.op};`}
      />
    ))
  }
</div>
