---
// Logos are each partner's own official mark (in-repo SVG for CoW/Bungee,
// official org marks for the rest), used for factual "built with" attribution.
const items = [
  { name: 'CoW Protocol',    note: 'Settlement stack we forked.',                  logo: '/logos/partners/cow.svg' },
  { name: 'Aleph Cloud',     note: 'Decentralized compute infra.',                 logo: '/logos/partners/aleph.png' },
  { name: 'LibertAI',        note: 'LLM for natural-language intent parsing.',     logo: '/logos/partners/libertai.png' },
  { name: 'Trail of Bits',   note: 'Security audits.',                             logo: '/logos/partners/trailofbits.png' },
  { name: 'NEAR Intents',    note: 'Cross-chain bridging to Solana + Bitcoin.',    logo: '/logos/partners/near.png' },
  { name: 'Bungee',          note: 'Bridge aggregation.',                          logo: '/logos/partners/bungee.svg' },
]
---
<section class="built-on">
  <div class="built-inner">
    <h2 class="reveal-up" data-reveal>
      Built with the tools and partners <span class="accent">that earned our trust.</span>
    </h2>
    <p class="sub reveal-up" data-reveal>
      Forked from CoW Protocol's settlement stack. Audited by Trail of Bits. Powered by Aleph Cloud compute. LLM intent parsing via LibertAI. Cross-chain routing via NEAR Intents and Bungee.
    </p>
    <div class="built-grid stagger">
      {items.map(item => (
        <div class="built-item reveal-up" data-reveal>
          <div class="built-head">
            <span class="built-logo">
              <img src={item.logo} alt={`${item.name} logo`} width="26" height="26" loading="lazy" decoding="async" />
            </span>
            <span class="built-name">{item.name}</span>
          </div>
          <span class="built-note">{item.note}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .built-on { padding: 80px 56px; text-align: center; }
  .built-inner { max-width: 1200px; margin: 0 auto; }
  h2 {
    font-size: 32px;
    line-height: 1.15;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }
  .sub {
    color: var(--ophis-fg-muted);
    margin: 0 auto 48px;
    max-width: 680px;
    font-size: 15px;
    line-height: 1.6;
  }
  .built-grid {
    display: grid;
    /* minmax(0, 1fr) (not bare 1fr) lets columns shrink below the cards'
       min-content so they never force a row wider than the viewport. */
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    text-align: left;
  }
  .built-item {
    background: var(--ophis-surface);
    border: 1px solid var(--ophis-border);
    border-radius: var(--ophis-radius-sm);
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .built-head {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .built-logo {
    width: 38px;
    height: 38px;
    border-radius: 9px;
    background: #fff;
    display: grid;
    place-items: center;
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid var(--ophis-border);
  }
  .built-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .built-name {
    font-weight: 600;
    font-size: 15px;
    color: var(--ophis-saffron-60);
  }
  .built-note {
    font-size: 13px;
    color: var(--ophis-fg-muted);
    line-height: 1.4;
  }
  @media (max-width: 720px) {
    .built-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    h2 { font-size: 26px; }
  }
  /* Phones: drop the 56px side padding (it consumed 112px of a 320px viewport
     and forced horizontal page overflow) to match the .protocols breakpoint. */
  @media (max-width: 560px) {
    .built-on { padding: 64px 20px; }
  }
  @media (max-width: 400px) {
    .built-grid { grid-template-columns: 1fr; }
  }
</style>
