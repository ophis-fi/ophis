---
const code = `import {
  ophisDefaultPartnerFee,
  OPHIS_PARTNER_FEE_RECIPIENT,
} from '@ophis/sdk'

// Resolve Ophis's default partner-fee config for the chain
// (price-improvement-bps capped by max-volume-bps).
const partnerFee = ophisDefaultPartnerFee(/* chainId */ 10)

// partnerFee = {
//   recipient: OPHIS_PARTNER_FEE_RECIPIENT,
//   bps: 2500,           // 25% of price-improvement
//   maxVolumeBps: 50,    // capped at 0.5% of volume
// }

// Plug into your CoW order's appData: receiver-pin and chain-id
// checks happen in buildOphisAppDataPartnerFee() under the hood.`
---
<section class="sdk" id="sdk">
  <div class="sdk-inner">
    <div class="sdk-copy reveal-up" data-reveal>
      <span class="sdk-tag">@ophis/sdk</span>
      <h2>Ship integrations <span class="accent">in an afternoon.</span></h2>
      <p>
        Partner-fee defaults, chain registry, settlement-address resolution, and agent-safety guards: everything an integrator needs to ship without footguns.
      </p>
      <div class="ctas">
        {/* STOPGAP 2026-05-29: @ophis/sdk is not on npm yet (registry 404), so the
            npm-install button is shown as a non-clickable "soon" chip rather than a
            dead link: the SDK code is live on GitHub today. ON PUBLISH, restore the
            live button by replacing the <span class="cta-soon"> below with:
            <a class="cta-secondary" href="https://www.npmjs.com/package/@ophis/sdk" rel="noopener">npm i @ophis/sdk</a> */}
        <a class="cta-secondary cta-primary" href="https://github.com/ophis-fi/ophis/tree/main/packages/sdk" rel="noopener">Get the SDK on GitHub</a>
        <span class="cta-soon" aria-disabled="true" title="Publishing to npm soon: available on GitHub today">
          <span class="cmd">npm i @ophis/sdk</span><span class="soon-badge">soon</span>
        </span>
      </div>
    </div>
    <div class="sdk-code reveal-up" data-reveal>
      <div class="code-frame">
        <div class="tabs"><div class="tab active">JavaScript</div></div>
        <pre class="code-body"><code>{code}</code></pre>
      </div>
    </div>
  </div>
</section>

<style>
  .sdk { padding: 80px 56px; }
  .sdk-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 50px;
    align-items: center;
  }
  /* Let each grid column shrink below its content's min-content so the code
     block's own overflow-x:auto handles long lines instead of forcing the
     column (and the page) wider than the viewport. */
  .sdk-inner > * { min-width: 0; }
  .sdk-tag {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 4px;
    background: rgba(242, 166, 62, 0.12);
    color: var(--ophis-saffron-60);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    margin-bottom: 16px;
  }
  h2 {
    font-size: 40px;
    line-height: 1.1;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }
  .sdk-copy p {
    color: var(--ophis-fg-muted);
    margin-bottom: 24px;
    line-height: 1.5;
  }
  .ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .cta-secondary {
    color: var(--ophis-fg);
    padding: 12px 22px;
    border-radius: var(--ophis-radius-sm);
    font-size: 14px;
    font-weight: 500;
    border: 1px solid var(--ophis-border);
    text-decoration: none;
    transition: border-color 150ms ease;
  }
  .cta-secondary:hover { border-color: var(--ophis-fg-muted); }
  .cta-primary { background: rgba(242, 166, 62, 0.12); border-color: var(--ophis-saffron-60); }
  .cta-primary:hover { border-color: var(--ophis-saffron-60); background: rgba(242, 166, 62, 0.18); }
  /* Non-clickable "coming soon" chip for the npm command until @ophis/sdk is
     published. Keeps the npm-distribution signal without a dead link. */
  .cta-soon {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 18px;
    border-radius: var(--ophis-radius-sm);
    border: 1px dashed var(--ophis-border);
    font-size: 14px;
    color: var(--ophis-fg-muted);
    cursor: default;
  }
  .cta-soon .cmd { font-family: 'JetBrains Mono', monospace; }
  .cta-soon .soon-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--ophis-saffron-60);
    background: rgba(242, 166, 62, 0.12);
    padding: 2px 7px;
    border-radius: 4px;
  }
  .code-frame {
    background: #111114;
    border: 1px solid var(--ophis-border);
    border-radius: var(--ophis-radius);
    overflow: hidden;
  }
  .tabs {
    display: flex;
    gap: 4px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--ophis-border);
  }
  .tab {
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    background: var(--ophis-surface);
    color: var(--ophis-saffron-60);
  }
  .code-body {
    margin: 0;
    padding: 24px;
    font-family: 'JetBrains Mono', 'Menlo', monospace;
    font-size: 13px;
    line-height: 1.6;
    color: var(--ophis-fg-muted);
    overflow-x: auto;
    white-space: pre-wrap;
  }
  @media (max-width: 720px) {
    .sdk-inner { grid-template-columns: 1fr; gap: 32px; }
    h2 { font-size: 30px; }
  }
  /* Phones: drop the 56px side padding that pushed the content past the
     viewport edge (matches the .protocols breakpoint). */
  @media (max-width: 560px) {
    .sdk { padding: 64px 20px; }
  }
</style>
