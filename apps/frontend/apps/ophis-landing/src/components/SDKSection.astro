---
const code = `import {
  getOphisOrderbookUrl,
  getOphisOrderDomain,
  assertReceiverIsOwner,
} from '@ophis/sdk'

// The correct orderbook host per chain — Optimism is self-hosted,
// not api.cow.fi; the wrong host silently bypasses Ophis.
const orderbook = getOphisOrderbookUrl(/* chainId */ 10)

// The EIP-712 signing domain with the right per-chain verifying
// contract (cow-sdk's default is wrong on the Ophis-operated chains).
const domain = getOphisOrderDomain(10)

// Pin the receiver to the owner before signing — an unpinned
// receiver is the #1 drain vector for an automated signer.
assertReceiverIsOwner(owner, order.receiver)`
---
<section class="sdk" id="sdk">
  <div class="sdk-inner">
    <div class="sdk-copy reveal-up" data-reveal>
      <span class="sdk-tag">@ophis/sdk</span>
      <h2>Ship integrations <span class="accent">in an afternoon.</span></h2>
      <p>
        Correct orderbook hosts, per-chain signing domains, and agent-safety guards: everything an integrator needs to ship without footguns.
      </p>
      <div class="ctas">
        <a class="cta-secondary cta-primary" href="https://www.npmjs.com/package/@ophis/sdk" rel="noopener">npm i @ophis/sdk</a>
        <a class="cta-secondary" href="https://github.com/ophis-fi/ophis/tree/main/packages/sdk" rel="noopener">Get the SDK on GitHub</a>
      </div>
      <div class="mcp-line">
        <span class="mcp-label">Or give an agent the whole toolset, keyless:</span>
        <code>claude mcp add --transport http ophis https://mcp.ophis.fi/mcp</code>
        <a href="https://docs.ophis.fi/ai-agents#connect-your-mcp-client" rel="noopener">Config for Cursor, Claude Desktop, VS Code, and OpenAI</a>
      </div>
    </div>
    <div class="sdk-code reveal-up" data-reveal>
      <div class="code-frame">
        <div class="tabs"><div class="tab active">JavaScript</div></div>
        <pre class="code-body"><code>{code}</code></pre>
      </div>
    </div>
  </div>
</section>

<style>
  .sdk { padding: 80px 56px; }
  .sdk-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 50px;
    align-items: center;
  }
  /* Let each grid column shrink below its content's min-content so the code
     block's own overflow-x:auto handles long lines instead of forcing the
     column (and the page) wider than the viewport. */
  .sdk-inner > * { min-width: 0; }
  .sdk-tag {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 4px;
    background: rgba(242, 166, 62, 0.12);
    color: var(--ophis-saffron-60);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    margin-bottom: 16px;
  }
  h2 {
    font-size: 40px;
    line-height: 1.1;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }
  .sdk-copy p {
    color: var(--ophis-fg-muted);
    margin-bottom: 24px;
    line-height: 1.5;
  }
  .ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .mcp-line { margin-top: 24px; display: flex; flex-direction: column; gap: 8px; }
  .mcp-label { color: var(--ophis-fg-muted); font-size: 13px; }
  .mcp-line code {
    display: block;
    font-family: 'JetBrains Mono', 'Menlo', monospace;
    font-size: 12px;
    color: var(--ophis-fg);
    background: #111114;
    border: 1px solid var(--ophis-border);
    border-radius: var(--ophis-radius-sm);
    padding: 10px 12px;
    overflow-x: auto;
    white-space: nowrap;
  }
  .mcp-line a { color: var(--ophis-saffron-60); font-size: 13px; text-decoration: none; }
  .mcp-line a:hover { text-decoration: underline; }
  .cta-secondary {
    color: var(--ophis-fg);
    padding: 12px 22px;
    border-radius: var(--ophis-radius-sm);
    font-size: 14px;
    font-weight: 500;
    border: 1px solid var(--ophis-border);
    text-decoration: none;
    transition: border-color 150ms ease;
  }
  .cta-secondary:hover { border-color: var(--ophis-fg-muted); }
  .cta-primary { background: rgba(242, 166, 62, 0.12); border-color: var(--ophis-saffron-60); }
  .cta-primary:hover { border-color: var(--ophis-saffron-60); background: rgba(242, 166, 62, 0.18); }
  .code-frame {
    background: #111114;
    border: 1px solid var(--ophis-border);
    border-radius: var(--ophis-radius);
    overflow: hidden;
  }
  .tabs {
    display: flex;
    gap: 4px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--ophis-border);
  }
  .tab {
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    background: var(--ophis-surface);
    color: var(--ophis-saffron-60);
  }
  .code-body {
    margin: 0;
    padding: 24px;
    font-family: 'JetBrains Mono', 'Menlo', monospace;
    font-size: 13px;
    line-height: 1.6;
    color: var(--ophis-fg-muted);
    overflow-x: auto;
    white-space: pre-wrap;
  }
  @media (max-width: 720px) {
    .sdk-inner { grid-template-columns: 1fr; gap: 32px; }
    h2 { font-size: 30px; }
  }
  /* Phones: drop the 56px side padding that pushed the content past the
     viewport edge (matches the .protocols breakpoint). */
  @media (max-width: 560px) {
    .sdk { padding: 64px 20px; }
  }
</style>
