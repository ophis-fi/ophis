---
import Base from '../../layouts/Base.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
)

const fmtDate = (d: Date) => new Intl.DateTimeFormat('en-US', { dateStyle: 'long' }).format(d)
---
<Base
  title="Blog — Ophis"
  description="Engineering and product writing from Ophis: intent-based, MEV-protected swaps for the agent era. AI agents, rebates, and multi-chain DeFi."
  canonical="https://ophis.fi/blog"
>
  <Nav />
  <main class="blog-index">
    <header class="blog-head section-bloom">
      <p class="eyebrow">Ophis Blog</p>
      <h1>Writing for the <span class="accent">agent era</span></h1>
      <p class="lede">
        Intent-based, MEV-protected swaps — and how to build on them. Notes on AI agents,
        rebates, and multi-chain DeFi.
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="empty">No posts yet — check back soon.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-card feat">
            <a class="post-link" href={`/blog/${post.id}`}>
              <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>{fmtDate(post.data.pubDate)}</time>
                {post.data.tags.slice(0, 3).map((t) => <span class="tag">{t}</span>)}
              </div>
              <h2>{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              <span class="read-more">Read<span aria-hidden="true"> →</span></span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
  <Footer />
</Base>

<style>
  .blog-index {
    max-width: 760px;
    margin: 0 auto;
    padding: 72px 24px 96px;
  }
  .blog-head {
    text-align: center;
    margin-bottom: 56px;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 12px;
    font-weight: 600;
    color: var(--ophis-saffron-60);
    margin: 0 0 14px;
  }
  .blog-head h1 {
    font-size: clamp(34px, 6vw, 52px);
    line-height: 1.08;
    letter-spacing: -0.025em;
    font-weight: 600;
    margin: 0 0 18px;
  }
  .lede {
    color: var(--ophis-fg-muted);
    font-size: 18px;
    line-height: 1.6;
    max-width: 56ch;
    margin: 0 auto;
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .post-card {
    border: 1px solid var(--ophis-border);
    border-radius: var(--ophis-radius);
    background: var(--ophis-surface);
  }
  .post-link {
    display: block;
    padding: 28px 28px 24px;
    text-decoration: none;
    color: inherit;
  }
  .post-link:focus-visible {
    outline: 2px solid var(--ophis-saffron-60);
    outline-offset: 3px;
    border-radius: var(--ophis-radius);
  }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    font-size: 12.5px;
    color: var(--ophis-fg-faded);
    margin-bottom: 12px;
  }
  .post-meta time {
    font-variant-numeric: tabular-nums;
  }
  .tag {
    border: 1px solid var(--ophis-border);
    border-radius: 999px;
    padding: 2px 10px;
    color: var(--ophis-fg-muted);
    font-size: 11.5px;
  }
  .post-card h2 {
    font-size: 23px;
    line-height: 1.25;
    letter-spacing: -0.01em;
    font-weight: 600;
    margin: 0 0 10px;
    color: var(--ophis-fg);
  }
  .post-desc {
    color: var(--ophis-fg-muted);
    font-size: 15.5px;
    line-height: 1.62;
    margin: 0 0 16px;
  }
  .read-more {
    color: var(--ophis-saffron-60);
    font-size: 14px;
    font-weight: 500;
  }
  .empty {
    text-align: center;
    color: var(--ophis-fg-faded);
    padding: 48px 0;
  }
  @media (max-width: 600px) {
    .blog-index { padding: 48px 18px 72px; }
    .post-link { padding: 22px 20px; }
  }
</style>
