---
import Base from '../../layouts/Base.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import { getCollection, render } from 'astro:content'
import { Image, getImage } from 'astro:assets'
import { isPublished } from '../../lib/posts'

export async function getStaticPaths() {
  const posts = await getCollection('blog', isPublished)
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }))
}

const { post } = Astro.props
const { Content } = await render(post)

// Trailing slash: CF Pages serves the directory-style route at /blog/<id>/ (it
// 308-redirects the no-slash form), so the canonical must match the 200 URL.
const url = `https://ophis.fi/blog/${post.id}/`
const fmtDate = (d: Date) => new Intl.DateTimeFormat('en-US', { dateStyle: 'long' }).format(d)

// Rough reading time from the raw markdown (≈200 wpm).
const words = (post.body ?? '').trim().split(/\s+/).filter(Boolean).length
const readingMin = Math.max(1, Math.round(words / 200))

// Per-post OG/social image: optimize the cover to the OG size (1280x640, matching
// Base's hardcoded og:image:width/height) in a social-safe format. Fall back to the
// shared default when a post has no cover. Absolute URL — scrapers need the origin.
const SITE = 'https://ophis.fi'
const ogImage = post.data.cover
  ? new URL((await getImage({ src: post.data.cover, width: 1280, height: 640, format: 'jpeg' })).src, SITE).href
  : `${SITE}/og-image.png`
// Per-post og:image:alt: describe the cover when the post has one (falling back to
// a title-derived line if coverAlt is unset), matching the /blog listing thumbnail
// pattern. When there is no cover we share the default /og-image.png, so leave
// imageAlt undefined and let Base's default (which describes that image) apply.
const ogImageAlt = post.data.cover
  ? (post.data.coverAlt ?? `Cover image for ${post.data.title}`)
  : undefined

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { '@type': 'Organization', name: post.data.author, url: 'https://ophis.fi/' },
  publisher: {
    '@type': 'Organization',
    name: 'Ophis',
    // Raster (not SVG): Google Article guidance / Rich Results validators prefer
    // a bitmap publisher logo.
    logo: { '@type': 'ImageObject', url: 'https://ophis.fi/og-image.png' },
  },
  image: ogImage,
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  ...(post.data.tags.length ? { keywords: post.data.tags.join(', ') } : {}),
}

// FAQPage structured data, parsed from the post's own "## FAQ" section (### question
// followed by its answer paragraphs). Single-sourced from the visible markdown, so
// the schema always matches on-page content (Google's FAQ requirement). Posts with
// no FAQ section emit nothing.
const stripMd = (s: string): string =>
  s
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // [text](url) -> text
    .replace(/[*_`]/g, '') // bold / italic / inline-code markers
    .replace(/\s+/g, ' ')
    .trim()

function faqPageSchema(body: string, pageUrl: string) {
  const lines = body.split(/\r?\n/)
  const start = lines.findIndex((l) => /^##\s+FAQ\s*$/i.test(l))
  if (start === -1) return null
  const items: { q: string; a: string }[] = []
  let q: string | null = null
  let answer: string[] = []
  const flush = () => {
    if (q) {
      const a = stripMd(answer.join(' '))
      if (a) items.push({ q: stripMd(q), a })
    }
    q = null
    answer = []
  }
  for (let i = start + 1; i < lines.length; i++) {
    const line = lines[i]
    if (/^##\s+/.test(line)) break // next H2 closes the FAQ section
    const h3 = line.match(/^###\s+(.+?)\s*$/)
    if (h3) {
      flush()
      q = h3[1]
      continue
    }
    if (q) answer.push(line)
  }
  flush()
  if (!items.length) return null
  return {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    '@id': `${pageUrl}#faq`,
    mainEntity: items.map((it) => ({
      '@type': 'Question',
      name: it.q,
      acceptedAnswer: { '@type': 'Answer', text: it.a },
    })),
  }
}
const faqLd = faqPageSchema(post.body ?? '', url)
---
<Base
  title={`${post.data.title} | Ophis`}
  description={post.data.description}
  canonical={url}
  ogType="article"
  image={ogImage}
  imageAlt={ogImageAlt}
>
  <meta slot="head" property="article:published_time" content={post.data.pubDate.toISOString()} />
  {post.data.updatedDate && (
    <meta slot="head" property="article:modified_time" content={post.data.updatedDate.toISOString()} />
  )}
  <meta slot="head" property="article:author" content={post.data.author} />
  {post.data.tags.map((t) => <meta slot="head" property="article:tag" content={t} />)}
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  {faqLd && <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)} />}

  <Nav />
  <main id="main" tabindex="-1" class="post">
    <article>
      <a class="back" href="/blog/">← All posts</a>
      <header class="post-header">
        <div class="post-meta">
          <time datetime={post.data.pubDate.toISOString()}>{fmtDate(post.data.pubDate)}</time>
          <span class="dot" aria-hidden="true">·</span>
          <span>{readingMin} min read</span>
        </div>
        <h1>{post.data.title}</h1>
        <p class="lede">{post.data.description}</p>
        {post.data.tags.length > 0 && (
          <ul class="tags">
            {post.data.tags.map((t) => <li>{t}</li>)}
          </ul>
        )}
      </header>
      {post.data.cover && (
        <Image
          class="post-cover"
          src={post.data.cover}
          alt={post.data.coverAlt ?? ''}
          widths={[480, 768, 1280]}
          sizes="(max-width: 760px) 100vw, 720px"
          loading="eager"
        />
      )}
      <div class="prose">
        <Content />
      </div>
    </article>

    <aside class="post-cta">
      <h2>Build agent-ready swaps</h2>
      <p>MEV-protected, self-custody, and you earn a rebate on every swap you route.</p>
      <div class="cta-row">
        <a class="cta-primary" href="https://docs.ophis.fi/ai-agents">Read the docs</a>
        <a class="cta-ghost" href="https://swap.ophis.fi/">Try a swap</a>
      </div>
    </aside>
  </main>
  <Footer />
</Base>

<style>
  .post {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 24px 96px;
  }
  .back {
    display: inline-block;
    color: var(--ophis-fg-faded);
    font-size: 14px;
    text-decoration: none;
    margin-bottom: 28px;
    transition: color 120ms ease;
  }
  .back:hover { color: var(--ophis-saffron-60); }
  .post-header {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--ophis-border);
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--ophis-fg-faded);
    margin-bottom: 18px;
  }
  .post-meta time { font-variant-numeric: tabular-nums; }
  .post-header h1 {
    font-size: clamp(30px, 5.2vw, 46px);
    line-height: 1.12;
    letter-spacing: -0.025em;
    font-weight: 600;
    margin: 0 0 18px;
  }
  .post-header .lede {
    color: var(--ophis-fg-muted);
    font-size: 19px;
    line-height: 1.55;
    margin: 0;
  }
  .tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0;
    margin: 22px 0 0;
  }
  .tags li {
    border: 1px solid var(--ophis-border);
    border-radius: 999px;
    padding: 3px 11px;
    color: var(--ophis-fg-muted);
    font-size: 12px;
  }

  /* ── Article body. The rendered Markdown HTML isn't scoped to this component,
        so target it with :global() under .prose. ─────────────────────────── */
  .post-cover {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 2 / 1;
    object-fit: cover;
    border: 1px solid var(--ophis-border);
    border-radius: var(--ophis-radius);
    margin: 0 0 36px;
  }

  .prose {
    font-size: 17.5px;
    line-height: 1.72;
    color: var(--ophis-fg-muted);
  }
  .prose :global(h2) {
    color: var(--ophis-fg);
    font-size: 27px;
    line-height: 1.2;
    letter-spacing: -0.015em;
    font-weight: 600;
    margin: 52px 0 16px;
    scroll-margin-top: 90px;
  }
  .prose :global(h3) {
    color: var(--ophis-fg);
    font-size: 20px;
    line-height: 1.3;
    font-weight: 600;
    margin: 36px 0 12px;
    scroll-margin-top: 90px;
  }
  .prose :global(p) { margin: 0 0 20px; }
  .prose :global(a) {
    color: var(--ophis-saffron-60);
    text-decoration: none;
    border-bottom: 1px solid rgba(242, 166, 62, 0.35);
    transition: border-color 120ms ease;
  }
  .prose :global(a:hover) { border-bottom-color: var(--ophis-saffron-60); }
  .prose :global(a:focus-visible) {
    outline: 2px solid var(--ophis-saffron-60);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .prose :global(strong) { color: var(--ophis-fg); font-weight: 600; }
  .prose :global(ul),
  .prose :global(ol) { margin: 0 0 20px; padding-left: 24px; }
  .prose :global(li) { margin: 0 0 8px; }
  .prose :global(li::marker) { color: var(--ophis-fg-faded); }

  /* Inline code */
  .prose :global(:not(pre) > code) {
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace;
    font-size: 0.86em;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--ophis-border);
    border-radius: 6px;
    padding: 1.5px 6px;
    color: var(--ophis-saffron-30);
    word-break: break-word;
  }
  /* Fenced code blocks (Shiki sets its own bg/colors inline) */
  .prose :global(pre) {
    font-size: 14px;
    line-height: 1.6;
    border: 1px solid var(--ophis-border);
    border-radius: var(--ophis-radius);
    padding: 18px 20px;
    overflow-x: auto;
    margin: 0 0 24px;
    -webkit-overflow-scrolling: touch;
  }
  .prose :global(pre code) {
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace;
  }

  /* Tables (e.g. the MCP tools list) */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 14.5px;
    margin: 0 0 24px;
    display: block;
    overflow-x: auto;
  }
  .prose :global(th),
  .prose :global(td) {
    text-align: left;
    padding: 10px 14px;
    border: 1px solid var(--ophis-border);
    vertical-align: top;
  }
  .prose :global(th) { color: var(--ophis-fg); font-weight: 600; background: rgba(255, 255, 255, 0.03); }

  .prose :global(blockquote) {
    margin: 0 0 24px;
    padding: 4px 0 4px 20px;
    border-left: 3px solid var(--ophis-saffron-60);
    color: var(--ophis-fg-muted);
  }
  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--ophis-border);
    margin: 40px 0;
  }
  .prose :global(img) { max-width: 100%; height: auto; border-radius: var(--ophis-radius); }

  /* ── End-of-post CTA ──────────────────────────────────────────────────── */
  .post-cta {
    margin-top: 64px;
    padding: 32px;
    border: 1px solid var(--ophis-border);
    border-radius: var(--ophis-radius);
    background: var(--ophis-surface);
    text-align: center;
  }
  .post-cta h2 { font-size: 22px; font-weight: 600; margin: 0 0 8px; color: var(--ophis-fg); }
  .post-cta p { color: var(--ophis-fg-muted); margin: 0 0 20px; font-size: 15.5px; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .cta-primary {
    background: var(--ophis-saffron-60);
    color: var(--ophis-bg);
    padding: 10px 20px;
    border-radius: var(--ophis-radius-sm);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
  }
  .cta-ghost {
    border: 1px solid var(--ophis-border);
    color: var(--ophis-fg);
    padding: 10px 20px;
    border-radius: var(--ophis-radius-sm);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: border-color 120ms ease;
  }
  .cta-ghost:hover { border-color: rgba(242, 166, 62, 0.4); }

  @media (max-width: 600px) {
    .post { padding: 36px 18px 72px; }
    .prose { font-size: 16.5px; }
    .post-cta { padding: 24px 20px; }
  }
</style>
