/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/_assets/*
  Cache-Control: public, max-age=31536000, immutable

# Brand/protocol logos get corrected over time, so they must NOT be immutable.
# This rule sits after /*.svg and /*.png so it wins for /logos/* (CF Pages uses
# the last matching rule per header). Filenames are still version-bumped
# (e.g. uniswap-v2.svg) when a mark changes, which busts any already-cached
# immutable copy; this revalidatable policy keeps the year-long staleness trap
# from recurring on the next in-place edit.
/logos/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/
  Cache-Control: public, max-age=300, must-revalidate
