/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-l2grA/0G1thOQNWg4HyVULrnV2lL6HwaEsgqFCqkV7Y=' 'sha256-fUv2t8ZBpNKDnHv7gyyxSjTZqBa1qlbDcufWvLWAwj8=' 'sha256-OjMWgQLPPSzN65f1zKvtlywmsmNSBxGiBnZwIFAyAqk=' 'sha256-QzWFZi+FLIx23tnm9SBU4aEgx4x8DsuASP07mfqol/c=' 'sha256-SaCkFfPruIdTXT8/97JArQmGxiJAL2o4bBDvSgJ5y3Q=' 'sha256-SuinMiccMvfxH4Wsw20lp4ZO7yXeJPr2zgCG1khIh7o=' 'sha256-41nY4CI9KIsvLKdh0yJpWHVADO52MYlEV2kEnt1/Q5U=' 'sha256-ct6uG2R9iHP3L80cTZEge8KmxG5DEgLY2FiLHvK8yOA=' 'sha256-pPd0moqs0fdy6rPxWTXmehMxj2qTku5sFR1lf/NFK2g=' 'sha256-4HnrXw7IovHmw279Hi2cSD2Oz5V4Likyb4imPLRa8BM=' 'sha256-nwRIAfb2LS5vhVngnsBLGcsDxt5guB6mspiGxzPPPKg=' 'sha256-Ya0pUYrC7nM5Cn/056TyVuEiz6dFGrzmkWzgON0pF0U=' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.google-analytics.com; font-src 'self'; connect-src 'self' https://swap.ophis.fi https://ophis.fi https://www.googletagmanager.com https://*.google-analytics.com https://*.analytics.google.com; frame-ancestors 'none'; form-action 'self'; base-uri 'self'
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  # Cloudflare Pages injects `Access-Control-Allow-Origin: *` on every response by
  # default. On HTML that wildcard contradicts the same-origin CORP above, so detach
  # it here and re-attach it below only on the machine-readable endpoints where
  # cross-origin reads are actually wanted (agents / AEO crawlers fetching the API
  # surface). `!` detaches a platform-set header; the per-path rules below re-add it.
  ! Access-Control-Allow-Origin

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/_assets/*
  Cache-Control: public, max-age=31536000, immutable

# NOTE: CF Pages _headers COMBINES all matching rules (duplicate headers are
# comma-joined), it does NOT override. So a `/logos/*` rule could not relax the
# `/*.svg` + `/*.png` immutable policy here — it would just append a second,
# conflicting Cache-Control. Mutable assets (e.g. brand logos that get
# corrected) are instead cache-busted by version-bumping the filename
# (uniswap.svg -> uniswap-v2.svg); see ProtocolsSection.astro.

/
  Cache-Control: public, max-age=300, must-revalidate
  # Agent-discovery Link headers (RFC 8288 / RFC 9727): point agents at the API
  # catalog, machine + human API docs, the MCP server card, and llms.txt.
  Link: </.well-known/api-catalog>; rel="api-catalog", </openapi.json>; rel="service-desc"; type="application/json", <https://docs.ophis.fi/>; rel="service-doc", </.well-known/mcp.json>; rel="service-meta"; type="application/json", </llms.txt>; rel="describedby"; type="text/plain"

# RFC 9727 API catalog: force its media type (extension-less file) AND echo the
# api-catalog Link on the resource itself, so a HEAD/GET directly against the
# catalog endpoint is self-describing (the root `/` Link rule does not match here).
/.well-known/api-catalog
  Content-Type: application/linkset+json; charset=utf-8
  Link: </.well-known/api-catalog>; rel="api-catalog"

# Re-attach wildcard CORS only on the machine-readable endpoints (detached from
# HTML by the `! Access-Control-Allow-Origin` rule under `/*` above). These are the
# public, credential-less API surface that agents/AEO crawlers fetch cross-origin.
# CF Pages COMBINES matching rules, so these re-add ACAO for these paths only.
/openapi.json
  Access-Control-Allow-Origin: *

/llms.txt
  Access-Control-Allow-Origin: *

/.well-known/*
  Access-Control-Allow-Origin: *
