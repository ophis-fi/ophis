/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/_assets/*
  Cache-Control: public, max-age=31536000, immutable

# NOTE: CF Pages _headers COMBINES all matching rules (duplicate headers are
# comma-joined), it does NOT override. So a `/logos/*` rule could not relax the
# `/*.svg` + `/*.png` immutable policy here — it would just append a second,
# conflicting Cache-Control. Mutable assets (e.g. brand logos that get
# corrected) are instead cache-busted by version-bumping the filename
# (uniswap.svg -> uniswap-v2.svg); see ProtocolsSection.astro.

/
  Cache-Control: public, max-age=300, must-revalidate
  # Agent-discovery Link headers (RFC 8288 / RFC 9727): point agents at the API
  # catalog, machine + human API docs, the MCP server card, and llms.txt.
  Link: </.well-known/api-catalog>; rel="api-catalog", </openapi.json>; rel="service-desc"; type="application/json", <https://docs.ophis.fi/>; rel="service-doc", </.well-known/mcp.json>; rel="service-meta"; type="application/json", </llms.txt>; rel="describedby"; type="text/plain"

# RFC 9727 API catalog: force its media type (extension-less file) AND echo the
# api-catalog Link on the resource itself, so a HEAD/GET directly against the
# catalog endpoint is self-describing (the root `/` Link rule does not match here).
/.well-known/api-catalog
  Content-Type: application/linkset+json; charset=utf-8
  Link: </.well-known/api-catalog>; rel="api-catalog"
