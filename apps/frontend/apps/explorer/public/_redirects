# Serve a real image for legacy /favicon.ico probes; the SPA catch-all otherwise
# returns index.html (HTML) for /favicon.ico. Modern clients use the <link rel=icon> PNGs.
/favicon.ico  /favicon-light-mode.png  200

# Vite copies the app's own package.json into the build root, which would
# otherwise be served verbatim and disclose dependency names + versions.
# CF Pages _redirects are always followed regardless of whether a static
# asset matches, so this 404s the path even though the file exists in dist.
/package.json  /404  404
