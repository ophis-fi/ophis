<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sitemap for the Ophis Cloudflare Pages deploy that backs BOTH swap.ophis.fi
  and business.ophis.fi (one project, two custom domains; functions/_middleware.ts
  rewrites business.ophis.fi/ to /business/). This one file is served at both
  swap.ophis.fi/sitemap.xml and business.ophis.fi/sitemap.xml, so it lists the
  canonical URLs for BOTH hosts' own pages:
   - swap.ophis.fi/{,about,learn,brand,legal} (the swap app + its content routes)
   - business.ophis.fi/ (the institutional page)
  A host-validating crawler self-selects the entries matching the host it fetched
  the sitemap from, so each domain gets its own pages indexed; together they stay
  consistent with the shared robots.txt Host/Sitemap directives.

  Excluded on purpose:
   - The landing (ophis.fi) is a SEPARATE deploy with its OWN sitemap listing its
     ophis.fi URLs; listing them here would point this deploy's sitemap at a
     different deploy (and ophis.fi/about,/legal,/brand soft-404 on the landing).
   - The cross-domain canonical-host choice for /about,/legal,/brand,/learn (they
     resolve on both ophis.fi and swap.ophis.fi) is a separate, still-open decision.
   - Docs live at https://docs.ophis.fi with a Docusaurus-generated sitemap.
   - Trading routes (/:chainId/swap/*) are excluded as user-state-dependent and
     not useful to index.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://swap.ophis.fi/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://business.ophis.fi/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  <url>
    <loc>https://swap.ophis.fi/about</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  <url>
    <loc>https://swap.ophis.fi/learn</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  <url>
    <loc>https://swap.ophis.fi/brand</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <url>
    <loc>https://swap.ophis.fi/legal</loc>
    <changefreq>yearly</changefreq>
    <priority>0.4</priority>
  </url>
</urlset>
