# Ophis ACP seller handler configuration.
# Never commit a real .env. At deploy, source the key from the macOS keychain
# (security find-generic-password -s ophis-acp-whitelisted-signer -w).

# A SEPARATE wallet key, whitelisted against the Ophis agent in the Virtuals
# dashboard. NOT the agent's Privy embedded-wallet key. It only authorizes ACP
# job-lifecycle actions on Base; it never touches user funds or signs swaps.
OPHIS_ACP_WHITELISTED_KEY=0x

# The Ophis agent's numeric ACP entity id (from the Virtuals dashboard;
# distinct from the agent UUID 019f28b9-...).
OPHIS_ACP_ENTITY_ID=

# The registered Ophis agent EVM wallet address.
OPHIS_ACP_WALLET_ADDRESS=0x
